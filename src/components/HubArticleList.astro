---
import { getCollection } from 'astro:content';

interface Props {
  hub: string;
  heading?: string;
}

const { hub, heading = 'Guides in This Section' } = Astro.props;

const entries = (await getCollection('articles', (e) => e.data.hub === hub)).sort(
  (a, b) => a.data.order - b.data.order
);
const items = entries.map((e) => ({
  slug: e.id.replace(/\.mdx?$/, '').split('/')[1],
  data: e.data,
}));
---

{items.length > 0 && (
  <section>
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-8 border-l-4 border-emerald-500 pl-4">
      {heading}
    </h2>
    <div class="grid md:grid-cols-2 gap-4">
      {items.map(({ slug, data }) => (
        <a
          href={`/${hub}/${slug}/`}
          class="group block bg-slate-900/40 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 transition-all hover:-translate-y-0.5"
        >
          <div class="flex items-center justify-between mb-3">
            <span class="text-[9px] font-black uppercase tracking-widest text-emerald-500">Guide</span>
            <span class="text-[9px] text-slate-600 font-bold uppercase tracking-widest">{data.reading_time} min read</span>
          </div>
          <h3 class="text-white font-black uppercase tracking-tighter text-base mb-2 group-hover:text-emerald-400 transition-colors leading-snug">
            {data.title}
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed">{data.description}</p>
          <span class="mt-4 inline-block text-[10px] font-black uppercase tracking-widest text-emerald-500">Read →</span>
        </a>
      ))}
    </div>
  </section>
)}
