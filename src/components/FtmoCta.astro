---
interface Props {
  variant?: 'banner' | 'card' | 'inline';
  accountSize?: string;
}

const { variant = 'banner', accountSize = '$100,000' } = Astro.props;

const AFFILIATE_URL = "https://trader.ftmo.com/?affiliates=ePACbqdYAbKwZHXxkICk";
---

{variant === 'banner' && (
  <div class="bg-gradient-to-r from-emerald-900/30 to-slate-950 border border-emerald-500/30 rounded-2xl p-6 md:p-8">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-2">FTMO — Official Partner</p>
        <h3 class="text-xl md:text-2xl font-black uppercase tracking-tighter text-white mb-2">
          Ready to Trade a Funded Account?
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed max-w-lg">
          FTMO is the world's most recognized prop firm. Start with a {accountSize} challenge — use this calculator to size every trade before you place it.
        </p>
        <p class="text-slate-600 text-[9px] uppercase tracking-widest font-bold mt-3">
          ★ Affiliate link — TRADE90 earns a commission at no extra cost to you
        </p>
      </div>
      <div class="flex flex-col gap-3 shrink-0">
        <a
          href={AFFILIATE_URL}
          target="_blank"
          rel="noopener sponsored"
          class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-sm px-6 py-3 rounded-xl transition-colors whitespace-nowrap"
        >
          Start FTMO Challenge →
        </a>
        <a
          href="/ftmo-position-size-calculator/"
          class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-emerald-500 text-center transition-colors"
        >
          FTMO Position Size Calculator
        </a>
      </div>
    </div>
  </div>
)}

{variant === 'card' && (
  <div class="bg-slate-900/60 border border-emerald-500/25 rounded-2xl p-6 text-center">
    <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">FTMO — Official Partner</p>
    <p class="text-white font-black text-lg uppercase tracking-tighter mb-2">Get Funded with FTMO</p>
    <p class="text-slate-400 text-sm mb-5 leading-relaxed">
      The #1 prop firm for US traders. {accountSize} challenges available. Use TRADE90 to size every trade.
    </p>
    <a
      href={AFFILIATE_URL}
      target="_blank"
      rel="noopener sponsored"
      class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-xs px-5 py-2.5 rounded-xl transition-colors"
    >
      Start FTMO Challenge →
    </a>
    <p class="text-slate-700 text-[9px] uppercase tracking-widest font-bold mt-3">
      Affiliate link — we earn a small commission at no cost to you
    </p>
  </div>
)}

{variant === 'inline' && (
  <span class="inline-flex flex-col gap-0.5">
    <a
      href={AFFILIATE_URL}
      target="_blank"
      rel="noopener sponsored"
      class="inline-flex items-center gap-1.5 text-emerald-400 hover:text-emerald-300 font-black text-sm underline decoration-emerald-500/40 underline-offset-2 transition-colors"
    >
      Start your FTMO challenge →
    </a>
    <span class="text-slate-700 text-[9px] uppercase tracking-widest">(affiliate link)</span>
  </span>
)}
