---
// Newsletter signup. Posts to /api/subscribe (a Cloudflare Pages Function
// that forwards to Brevo). Progressive enhancement: with JS, the form
// submits via fetch and shows an inline status; without JS, it falls back
// to a normal POST and the Function returns a full HTML confirmation page.
---

<section class="max-w-3xl mx-auto py-20 px-6">
  <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-8 md:p-12 text-center">
    <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">The Weekly</p>
    <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter text-white mb-3">
      One Email. Every Week. No Noise.
    </h2>
    <p class="text-slate-400 text-sm leading-relaxed max-w-lg mx-auto mb-8">
      Practical notes on trading psychology, risk management, and disciplined execution — written for funded traders. No signals, no hype, no income claims. Unsubscribe anytime.
    </p>

    <form id="newsletter-form" method="POST" action="/api/subscribe" class="max-w-md mx-auto" novalidate>
      <p class="absolute -left-[9999px]" aria-hidden="true">
        <label>Leave this field empty: <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
      </p>
      <div id="newsletter-fields" class="flex flex-col sm:flex-row gap-3">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-grow bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white text-sm outline-none transition-colors"
        />
        <button
          id="newsletter-submit"
          type="submit"
          class="shrink-0 bg-emerald-500 hover:bg-emerald-400 disabled:opacity-50 disabled:cursor-not-allowed text-black font-black uppercase tracking-widest text-xs px-6 py-3 rounded-xl transition-colors"
        >
          Subscribe
        </button>
      </div>
      <p id="newsletter-msg" class="text-xs font-bold mt-4 hidden" role="status" aria-live="polite"></p>
    </form>

    <p class="text-slate-600 text-[10px] leading-relaxed mt-6">
      Educational content only. TRADE90 does not provide financial advice.
      See our <a href="/privacy/" class="text-slate-400 hover:text-emerald-400 transition-colors">privacy policy</a>.
    </p>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById("newsletter-form");
    const fields = document.getElementById("newsletter-fields");
    const submitBtn = document.getElementById("newsletter-submit");
    const msg = document.getElementById("newsletter-msg");
    if (!form) return;

    function showMsg(text, ok) {
      msg.textContent = text;
      msg.classList.remove("hidden", "text-emerald-400", "text-rose-400");
      msg.classList.add(ok ? "text-emerald-400" : "text-rose-400");
    }

    form.addEventListener("submit", function (e) {
      const email = form.querySelector('input[name="email"]');
      if (!email || !email.checkValidity()) return; // let native validation show its own message

      e.preventDefault();
      submitBtn.disabled = true;

      fetch(form.action, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({
          email: email.value,
          website: form.querySelector('input[name="website"]').value,
        }),
      })
        .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
        .then(function (result) {
          if (result.ok && result.data.ok) {
            fields.classList.add("opacity-40", "pointer-events-none");
            showMsg("You're on the list. Check your inbox to confirm.", true);
          } else {
            showMsg((result.data && result.data.error) || "Something went wrong. Please try again.", false);
            submitBtn.disabled = false;
          }
        })
        .catch(function () {
          showMsg("Something went wrong. Please try again.", false);
          submitBtn.disabled = false;
        });
    });
  })();
</script>
