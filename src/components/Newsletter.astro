---
// Newsletter signup. Uses Netlify Forms (auto-detected from the static HTML at
// deploy time). Progressive enhancement shows an inline success state; if JS is
// off, the native POST still submits to Netlify.
---

<section class="max-w-3xl mx-auto py-20 px-6">
  <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-8 md:p-12 text-center">
    <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">The Weekly</p>
    <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter text-white mb-3">
      One Email. Every Week. No Noise.
    </h2>
    <p class="text-slate-400 text-sm leading-relaxed max-w-lg mx-auto mb-8">
      Practical notes on trading psychology, risk management, and disciplined execution — written for funded traders. No signals, no hype, no income claims. Unsubscribe anytime.
    </p>

    <form
      id="newsletter-form"
      name="newsletter"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="max-w-md mx-auto"
    >
      <input type="hidden" name="form-name" value="newsletter" />
      <p class="hidden">
        <label>Don't fill this out if you're human: <input name="bot-field" /></label>
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-grow bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white text-sm outline-none transition-colors"
        />
        <button
          type="submit"
          class="shrink-0 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-xs px-6 py-3 rounded-xl transition-colors"
        >
          Subscribe
        </button>
      </div>
      <p id="newsletter-msg" class="text-emerald-400 text-xs font-bold mt-4 hidden" role="status" aria-live="polite">
        You're on the list. Check your inbox to confirm.
      </p>
    </form>

    <p class="text-slate-600 text-[10px] leading-relaxed mt-6">
      Educational content only. TRADE90 does not provide financial advice.
      See our <a href="/privacy/" class="text-slate-400 hover:text-emerald-400 transition-colors">privacy policy</a>.
    </p>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById("newsletter-form");
    const msg = document.getElementById("newsletter-msg");
    if (!form) return;
    form.addEventListener("submit", function (e) {
      const email = form.querySelector('input[name="email"]');
      if (!email || !email.value || !email.checkValidity()) return; // let native validation handle it
      e.preventDefault();
      const body = new URLSearchParams(new FormData(form)).toString();
      fetch("/", { method: "POST", headers: { "Content-Type": "application/x-www-form-urlencoded" }, body })
        .catch(function () {})
        .finally(function () {
          form.querySelector(".flex").classList.add("opacity-40", "pointer-events-none");
          if (msg) msg.classList.remove("hidden");
        });
    });
  })();
</script>
