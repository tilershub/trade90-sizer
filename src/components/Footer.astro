---
const currentYear = new Date().getFullYear();

const columns = [
  {
    heading: 'Learn',
    links: [
      { href: '/psychology/', label: 'Trading Psychology' },
      { href: '/risk-management/', label: 'Risk Management' },
      { href: '/trading-plans/', label: 'Trading Plans' },
      { href: '/prop-firms/', label: 'Prop Firms' },
      { href: '/performance/', label: 'Performance' },
    ],
  },
  {
    heading: 'Tools',
    links: [
      { href: '/tools/position-size-calculator/', label: 'Position Size Calculator' },
      { href: '/risk-reward-calculator/', label: 'Risk / Reward Calculator' },
      { href: '/tools/drawdown-calculator/', label: 'Drawdown Calculator' },
      { href: '/pip-value-calculator/', label: 'Pip Value Calculator' },
      { href: '/tools/', label: 'All Tools' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { href: '/about/', label: 'About TRADE90' },
      { href: '/editorial-policy/', label: 'Editorial Policy' },
      { href: '/blog/', label: 'Blog' },
      { href: '/contact/', label: 'Contact' },
    ],
  },
];
---

<footer class="bg-black border-t border-slate-900 py-16 px-6 mt-12">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">

      <div class="col-span-2 md:col-span-1 space-y-4 max-w-xs">
        <h3 class="text-lg font-black text-white tracking-widest uppercase">
          TRADE<span class="text-emerald-500">90</span>
        </h3>
        <p class="text-slate-400 text-xs leading-relaxed">
          An education platform for funded traders. Practical guidance on psychology, risk management, and disciplined execution — with free professional tools and honest prop firm resources.
        </p>
      </div>

      {columns.map((col) => (
        <div class="space-y-4">
          <h4 class="text-white font-bold text-[11px] uppercase tracking-[0.2em]">{col.heading}</h4>
          <nav class="flex flex-col gap-3">
            {col.links.map((link) => (
              <a href={link.href} class="text-slate-400 hover:text-emerald-400 text-xs font-medium transition-colors">{link.label}</a>
            ))}
          </nav>
        </div>
      ))}
    </div>

    <div class="border-t border-slate-900/60 pt-8">
      <p class="text-slate-500 text-[11px] leading-relaxed max-w-3xl mb-6">
        <strong class="text-slate-400">Risk disclosure.</strong> Trading involves substantial risk of loss and is not suitable for every investor. All content on TRADE90 is for educational purposes only and does not constitute financial, investment, or trading advice. Prop firm rules referenced on this site are typical structures that change frequently — always verify current terms on the firm's official website. Some links to prop firms are affiliate links; TRADE90 may earn a commission at no additional cost to you.
      </p>
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div class="flex flex-wrap gap-6">
          <a href="/disclaimer/" class="text-slate-500 hover:text-slate-300 text-[10px] uppercase font-bold transition-colors">Disclaimer</a>
          <a href="/privacy/" class="text-slate-500 hover:text-slate-300 text-[10px] uppercase font-bold transition-colors">Privacy Policy</a>
          <a href="/editorial-policy/" class="text-slate-500 hover:text-slate-300 text-[10px] uppercase font-bold transition-colors">Editorial Policy</a>
        </div>
        <p class="text-slate-600 text-[10px] uppercase tracking-[0.25em] font-mono">
          &copy; {currentYear} TRADE90
        </p>
      </div>
    </div>
  </div>
</footer>
