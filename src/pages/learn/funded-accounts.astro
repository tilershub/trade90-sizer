---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FtmoCta from '../../components/FtmoCta.astro';

const title = "Funded Account Trading Guide — How to Pass Prop Firm Challenges";
const description = "How drawdown limits work, FTMO challenge rules and account sizes, and the exact position sizing strategy used to pass Phase 1 and Phase 2 prop firm evaluations. Covers FTMO, E8, Apex, Topstep.";
const keywords = [
  "how to pass prop firm challenge",
  "funded account trading guide",
  "ftmo challenge rules",
  "prop firm challenge strategy",
  "ftmo position sizing",
  "funded trading drawdown limits",
  "prop firm evaluation guide",
  "apex topstep e8 challenge",
  "funded trader position sizing",
];

const site = Astro.site?.toString() || "https://tradeninety.com";

const ftmoAccounts = [
  { size: "$10,000",  target: "$1,000",   daily: "$500",     maxDD: "$1,000" },
  { size: "$25,000",  target: "$2,500",   daily: "$1,250",   maxDD: "$2,500" },
  { size: "$50,000",  target: "$5,000",   daily: "$2,500",   maxDD: "$5,000" },
  { size: "$100,000", target: "$10,000",  daily: "$5,000",   maxDD: "$10,000" },
  { size: "$200,000", target: "$20,000",  daily: "$10,000",  maxDD: "$20,000" },
];

const propFirms = [
  { name: "FTMO",                usAccess: "Yes",      daily: "5%",  maxDD: "10%",  model: "Phase 1 → Phase 2 → Funded", note: "Czech firm, global access" },
  { name: "E8 Funding",          usAccess: "Yes",      daily: "5%",  maxDD: "8%",   model: "Phase 1 → Phase 2 → Funded", note: "US-friendly" },
  { name: "Apex Trader Funding", usAccess: "Yes",      daily: "—",   maxDD: "6%",   model: "1-step evaluation",          note: "Futures-focused" },
  { name: "Topstep",             usAccess: "Yes",      daily: "2%",  maxDD: "6%",   model: "Step 1 → Step 2 → Funded",   note: "Futures, tight daily limit" },
  { name: "The Funded Trader",   usAccess: "Yes",      daily: "5%",  maxDD: "10%",  model: "Phase 1 → Phase 2 → Funded", note: "Forex + indices" },
  { name: "Funded Next",         usAccess: "Yes",      daily: "5%",  maxDD: "10%",  model: "1-step or 2-step",           note: "EU/US access" },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I pass an FTMO challenge?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "To pass FTMO Phase 1, you need to hit the 10% profit target while keeping daily losses below 5% and total drawdown below 10%. The key is position sizing: using 0.5% per trade ensures that even 10 consecutive losses only cost 4.9% — within the total drawdown limit. Most challenges are failed by traders who risk 1–2% per trade and hit a losing streak, not by traders with bad strategies.",
      },
    },
    {
      "@type": "Question",
      name: "What FTMO account sizes are available?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "FTMO offers challenge accounts at $10,000, $25,000, $50,000, $100,000, and $200,000. The profit target is 10% and the maximum drawdown is 10% across all account sizes. The daily loss limit is 5%. Drawdown is typically calculated from the highest equity reached.",
      },
    },
    {
      "@type": "Question",
      name: "Should I use starting balance or current equity for position sizing?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Always use current equity, not starting balance. If your $100,000 challenge is at $96,000, enter $96,000 in the calculator. Your risk percentage should always be calculated from your live equity — this automatically scales position sizes down as losses accumulate, reducing risk precisely when you can least afford it.",
      },
    },
    {
      "@type": "Question",
      name: "Can I trade multiple instruments simultaneously on a funded account?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, but you must track combined exposure. If you risk 0.5% on EUR/USD and 0.5% on Gold simultaneously, your total exposure is 1% of account equity — which is the Trade90 daily cap. Never let combined open risk exceed 1% of equity at any one time on a funded challenge.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Learn", item: `${site}/learn/` },
    { "@type": "ListItem", position: 3, name: "Funded Accounts Guide", item: `${site}/learn/funded-accounts/` },
  ],
};
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />

  <!-- Hero -->
  <section class="py-14 px-4 border-b border-slate-800 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-purple-900/10 via-slate-950 to-slate-950">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span>/</span>
        <a href="/learn/" class="hover:text-emerald-400 transition-colors">Learn</a>
        <span>/</span>
        <span class="text-slate-300">Funded Accounts</span>
      </nav>

      <span class="text-[9px] font-black uppercase tracking-widest text-purple-400 bg-purple-500/10 px-3 py-1 rounded-full mb-4 inline-block">Prop Firms Guide</span>
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-4 leading-tight">
        Funded Account<br/><span class="text-emerald-400">Trading Guide</span>
      </h1>
      <p class="text-slate-400 text-base leading-relaxed max-w-2xl mb-4">
        How prop firm challenges work, how drawdown limits are calculated, the FTMO account size reference table, and the exact position sizing strategy used to pass Phase 1 and Phase 2 evaluations.
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto py-16 px-6 space-y-16">

    <!-- How Funded Accounts Work -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        How Prop Firm Challenges Work
      </h2>
      <div class="space-y-4 text-slate-400 text-sm leading-relaxed">
        <p>
          A prop firm evaluation (or "challenge") is a paid assessment where you trade a simulated account according to specific rules. If you meet the profit target without breaching the drawdown limits, the firm funds you with a real account — typically keeping 10–20% of your profits as their fee.
        </p>
        <p>
          Most challenges run in two phases: Phase 1 requires hitting a higher profit target (typically 8–10%), Phase 2 requires a lower target (4–5%). Both phases enforce the same drawdown limits. Once funded, you trade live capital and split profits on a set ratio (commonly 80/20 or 90/10 in your favour).
        </p>
        <p>
          The challenge fee is non-refundable if you fail — though many firms refund it with your first payout on a funded account. The fee ranges from $50 for a $5,000 account to $1,000+ for a $200,000 account.
        </p>
      </div>
    </section>

    <!-- Drawdown rules explained -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        How Drawdown Limits Are Calculated
      </h2>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
          <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-3">Daily Loss Limit (Typically 4–5%)</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            The maximum you can lose in a single trading day, measured from the start-of-day balance. On a $100,000 FTMO account with a 5% daily limit, you cannot lose more than $5,000 in one session — regardless of how many trades you take.
          </p>
          <div class="bg-slate-950/60 rounded-xl p-4 font-mono text-xs space-y-1">
            <p class="text-slate-500">$100k account, 5% daily limit</p>
            <p class="text-slate-200">Max daily loss = <span class="text-rose-400">$5,000</span></p>
            <p class="text-slate-200">At 0.5%/trade = <span class="text-emerald-400">10 losses to hit limit</span></p>
          </div>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
          <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-3">Maximum Drawdown (Typically 8–10%)</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            The maximum cumulative loss from your starting balance (or in some firms, from your highest equity). Once your account drops by the max drawdown percentage, the challenge ends regardless of daily performance. This is the harder constraint to manage.
          </p>
          <div class="bg-slate-950/60 rounded-xl p-4 font-mono text-xs space-y-1">
            <p class="text-slate-500">$100k account, 10% max DD</p>
            <p class="text-slate-200">Max total loss = <span class="text-rose-400">$10,000</span></p>
            <p class="text-slate-200">At 0.5%/trade = <span class="text-emerald-400">20 losses to hit limit</span></p>
          </div>
        </div>
      </div>

      <div class="bg-slate-900/40 border border-amber-500/20 rounded-2xl p-5">
        <p class="text-amber-400 font-black text-[10px] uppercase tracking-widest mb-2">Important</p>
        <p class="text-slate-400 text-sm leading-relaxed">
          Some prop firms calculate maximum drawdown from your <em>highest equity reached</em>, not just your starting balance. If you grow your account to $110,000 and the max drawdown is 10%, your new floor is $99,000 — lower than you might expect. Always verify the specific drawdown calculation method with your prop firm before trading.
        </p>
      </div>
    </section>

    <!-- FTMO Account Sizes Table -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-2 border-l-4 border-emerald-500 pl-4">
        FTMO Challenge: Account Sizes & Limits
      </h2>
      <p class="text-slate-500 text-xs uppercase tracking-widest font-bold pl-5 mb-6">
        Standard FTMO Challenge rules as of 2026 — verify current terms at ftmo.com
      </p>

      <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden mb-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="px-5 py-4 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Account Size</th>
              <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">10% Profit Target</th>
              <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">5% Daily Limit</th>
              <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">10% Max Drawdown</th>
            </tr>
          </thead>
          <tbody>
            {ftmoAccounts.map((row, i) => (
              <tr class={`border-b border-slate-800/50 ${i % 2 === 0 ? "" : "bg-slate-900/20"}`}>
                <td class="py-4 px-5 font-black text-white">{row.size}</td>
                <td class="py-4 px-5 text-right text-emerald-400 font-black">{row.target}</td>
                <td class="py-4 px-5 text-right text-slate-300">{row.daily}/day</td>
                <td class="py-4 px-5 text-right text-slate-300">{row.maxDD} total</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-slate-600 text-xs">TRADE90 is an FTMO affiliate partner. We may earn a commission if you purchase a challenge via our link, at no extra cost to you.</p>
    </section>

    <!-- Sizing Strategy for Challenges -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        The Exact Sizing Strategy for Passing Challenges
      </h2>

      <div class="space-y-4 mb-8">
        {[
          {
            n: "1",
            title: "Enter current equity, not starting balance",
            body: "Always use your live account equity in the calculator. As losses accumulate, your dollar risk per trade automatically decreases — protecting your remaining drawdown buffer. If you started at $100,000 and are now at $96,000, enter $96,000.",
          },
          {
            n: "2",
            title: "Set risk to 0.5% as your default",
            body: "For standard setups: 0.5%. For very high-conviction trades on a challenge where you're well within drawdown limits: up to 1%. Never exceed 1% per trade on any funded account, regardless of how confident you are.",
          },
          {
            n: "3",
            title: "Define your stop loss before opening the calculator",
            body: "Position your stop loss at the structural invalidation level — below support for longs, above resistance for shorts. Then calculate lot size based on that stop. Never reverse this sequence by choosing a lot size first.",
          },
          {
            n: "4",
            title: "Track daily exposure across all positions",
            body: "If you have two open trades both at 0.5% risk, your total exposure is 1% — the daily cap. Do not open more positions until one closes. Combined open risk counts against your daily budget.",
          },
          {
            n: "5",
            title: "Verify ADR consumption before entry",
            body: "Check how much of the instrument's Average Daily Range has already been consumed. If more than 70% of the ADR is used before your setup triggers, the trade has reduced remaining range and elevated stop-hunt risk — skip it.",
          },
        ].map(({ n, title, body }) => (
          <div class="flex gap-5 bg-slate-900/40 border border-slate-800 rounded-2xl p-5">
            <div class="w-8 h-8 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0">
              <span class="text-emerald-400 font-black text-sm">{n}</span>
            </div>
            <div>
              <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-2">{title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Prop Firm Comparison -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-2 border-l-4 border-emerald-500 pl-4">
        Prop Firm Comparison — US & Europe Access
      </h2>
      <p class="text-slate-500 text-xs uppercase tracking-widest font-bold pl-5 mb-6">
        All firms listed accept traders from USA and Europe. Rules accurate as of 2026.
      </p>

      <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden mb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-slate-800">
                <th class="px-5 py-4 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Firm</th>
                <th class="px-5 py-4 text-center text-[10px] font-black uppercase tracking-widest text-slate-500">US Access</th>
                <th class="px-5 py-4 text-center text-[10px] font-black uppercase tracking-widest text-slate-500">Daily Limit</th>
                <th class="px-5 py-4 text-center text-[10px] font-black uppercase tracking-widest text-slate-500">Max DD</th>
                <th class="px-5 py-4 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Model</th>
                <th class="px-5 py-4 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Notes</th>
              </tr>
            </thead>
            <tbody>
              {propFirms.map((firm, i) => (
                <tr class={`border-b border-slate-800/50 ${i % 2 === 0 ? "" : "bg-slate-900/20"}`}>
                  <td class="py-4 px-5 font-black text-white">{firm.name}</td>
                  <td class="py-4 px-5 text-center">
                    <span class="text-emerald-400 font-black text-xs">{firm.usAccess}</span>
                  </td>
                  <td class="py-4 px-5 text-center text-slate-300 font-mono">{firm.daily}</td>
                  <td class="py-4 px-5 text-center text-slate-300 font-mono">{firm.maxDD}</td>
                  <td class="py-4 px-5 text-slate-400">{firm.model}</td>
                  <td class="py-4 px-5 text-slate-500">{firm.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="text-slate-600 text-xs">Rules change — always verify at each firm's official website before purchasing a challenge.</p>
    </section>

    <!-- Worked Examples -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        Worked Examples — Common Challenge Accounts
      </h2>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          {
            label: "EUR/USD — $100k FTMO Challenge",
            rows: [["Account", "$100,000"], ["Risk", "0.5% = $500"], ["Stop Loss", "30 pips"], ["Pip Value", "$10.00/lot"], ["Lot Size", "1.67 lots"]],
            note: "$500 ÷ (30 × $10) = 1.67",
          },
          {
            label: "Gold — $50k Challenge",
            rows: [["Account", "$50,000"], ["Risk", "0.5% = $250"], ["Stop Loss", "200 points"], ["Pip Value", "$10.00/lot"], ["Lot Size", "0.125 lots"]],
            note: "$250 ÷ (200 × $10) = 0.125",
          },
          {
            label: "NAS100 — $25k Challenge",
            rows: [["Account", "$25,000"], ["Risk", "0.5% = $125"], ["Stop Loss", "100 points"], ["Pip Value", "$1.00/lot"], ["Lot Size", "1.25 lots"]],
            note: "$125 ÷ (100 × $1) = 1.25",
          },
        ].map(({ label, rows, note }) => (
          <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden">
            <div class="px-5 py-3 border-b border-slate-800 bg-slate-900/60">
              <h3 class="text-white font-black uppercase text-xs tracking-tighter">{label}</h3>
            </div>
            {rows.map(([k, v], i) => (
              <div class={`flex justify-between px-5 py-2.5 text-xs ${i % 2 === 0 ? "bg-slate-950/20" : ""}`}>
                <span class="text-slate-400">{k}</span>
                <span class={`font-mono font-bold ${k === "Lot Size" ? "text-emerald-400" : "text-slate-200"}`}>{v}</span>
              </div>
            ))}
            <div class="px-5 py-3 border-t border-slate-800/50">
              <p class="text-slate-600 text-[10px] font-mono">{note}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FTMO Affiliate CTA -->
    <FtmoCta variant="banner" />

    <!-- FAQ -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        Funded Account FAQ
      </h2>
      <div class="space-y-3">
        {[
          {
            q: "How do I pass an FTMO challenge?",
            a: "Hit the 10% profit target while keeping daily losses below 5% and total drawdown below 10%. The key is position sizing: using 0.5% per trade means 10 consecutive losses cost only 4.9% — within the total drawdown limit. Most challenges fail because of oversized positions during losing streaks, not bad strategies.",
          },
          {
            q: "What FTMO account sizes are available?",
            a: "FTMO offers $10,000, $25,000, $50,000, $100,000, and $200,000. The profit target is 10% and maximum drawdown is 10% across all sizes. Daily loss limit is 5%.",
          },
          {
            q: "Should I use starting balance or current equity?",
            a: "Always current equity. If your $100,000 challenge is at $96,000, enter $96,000 in the calculator. Position sizes automatically scale down as losses accumulate — reducing risk precisely when your account is most vulnerable.",
          },
          {
            q: "Can I trade multiple instruments simultaneously?",
            a: "Yes, but combined exposure counts. 0.5% on EUR/USD + 0.5% on Gold = 1% total daily exposure — which hits the Trade90 daily cap. Do not open additional positions until one closes when you're at the daily limit.",
          },
        ].map(({ q, a }) => (
          <details class="group bg-slate-900/40 border border-slate-800 hover:border-emerald-500/30 rounded-2xl overflow-hidden transition-colors">
            <summary class="flex justify-between items-center p-5 cursor-pointer font-bold text-slate-200 text-sm uppercase tracking-tight hover:text-white list-none">
              {q}
              <span class="text-emerald-500 group-open:rotate-45 transition-transform text-xl leading-none shrink-0 ml-4">+</span>
            </summary>
            <div class="px-5 pb-5 text-slate-400 text-sm leading-relaxed border-t border-slate-800/50 pt-4">{a}</div>
          </details>
        ))}
      </div>
    </section>

    <!-- Next guides -->
    <section class="border-t border-slate-800 pt-12">
      <h2 class="text-lg font-black uppercase tracking-tighter text-white mb-6">Continue Learning</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/learn/risk-management/" class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-5 transition-all">
          <p class="text-[9px] font-black uppercase tracking-widest text-emerald-500 mb-1">Framework</p>
          <h3 class="text-white font-black uppercase tracking-tighter text-sm mb-2 group-hover:text-emerald-400 transition-colors">Risk Management for Funded Traders →</h3>
          <p class="text-slate-400 text-xs leading-relaxed">The 0.5% rule, daily limits, drawdown survival tables, and the four rules.</p>
        </a>
        <a href="/" class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-5 transition-all">
          <p class="text-[9px] font-black uppercase tracking-widest text-emerald-500 mb-1">Tool</p>
          <h3 class="text-white font-black uppercase tracking-tighter text-sm mb-2 group-hover:text-emerald-400 transition-colors">Position Size Calculator →</h3>
          <p class="text-slate-400 text-xs leading-relaxed">Calculate exact lot sizes with the Trade90 Safety System enforced in real time.</p>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
