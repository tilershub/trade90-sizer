---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Trading Education Hub — Position Sizing, Risk Management, Funded Accounts";
const description = "Practical trading guides for forex and funded account traders. Learn position sizing, risk management frameworks, and how to pass prop firm challenges. Free, no fluff.";
const keywords = [
  "position sizing guide",
  "forex risk management guide",
  "funded trading guide",
  "prop firm risk management",
  "how to calculate position size",
  "trading education",
];

const guides = [
  {
    href: "/learn/position-sizing/",
    tag: "Foundation",
    title: "Position Sizing: The Complete Guide",
    desc: "The formula, how it works across forex, gold, indices and crypto, worked examples, and common mistakes that cost traders their accounts.",
    time: "12 min read",
    color: "border-emerald-500/30 hover:border-emerald-500",
  },
  {
    href: "/learn/risk-management/",
    tag: "Framework",
    title: "Risk Management for Funded Traders",
    desc: "The 0.5% rule, daily loss limits, drawdown survival tables, and the four-rule framework used by consistently profitable prop firm traders.",
    time: "10 min read",
    color: "border-blue-500/30 hover:border-blue-500",
  },
  {
    href: "/learn/funded-accounts/",
    tag: "Prop Firms",
    title: "Funded Account Trading Guide",
    desc: "How drawdown limits work, challenge rules explained, FTMO account sizes table, and the exact sizing strategy to pass Phase 1 and Phase 2.",
    time: "14 min read",
    color: "border-purple-500/30 hover:border-purple-500",
  },
];
---

<BaseLayout title={title} description={description} keywords={keywords} breadcrumbName="Learn">
  <section class="py-16 px-4 border-b border-slate-800 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-slate-800/20 via-slate-950 to-slate-950">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-300">Learn</span>
      </nav>

      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-4">
        Trading <span class="text-emerald-400">Education</span>
      </h1>
      <p class="text-slate-400 text-base leading-relaxed max-w-2xl mb-4">
        Three focused guides covering everything that matters: position sizing, risk management, and funded account trading. No padding, no repetition — one authoritative resource per topic.
      </p>
      <p class="text-slate-600 text-[10px] uppercase tracking-widest font-bold">
        For funded traders, prop firm candidates, and serious retail traders worldwide
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto py-16 px-6">
    <div class="grid md:grid-cols-3 gap-6">
      {guides.map(({ href, tag, title, desc, time, color }) => (
        <a
          href={href}
          class={`group block bg-slate-900/50 border ${color} rounded-2xl p-6 transition-all hover:-translate-y-0.5`}
        >
          <div class="flex items-center justify-between mb-4">
            <span class="text-[9px] font-black uppercase tracking-widest text-emerald-400 bg-emerald-500/10 px-2 py-1 rounded-full">{tag}</span>
            <span class="text-[9px] text-slate-600 font-bold">{time}</span>
          </div>
          <h2 class="text-white font-black uppercase tracking-tighter text-base mb-3 group-hover:text-emerald-400 transition-colors leading-snug">
            {title}
          </h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">{desc}</p>
          <span class="text-[10px] font-black uppercase tracking-widest text-emerald-500">Read Guide →</span>
        </a>
      ))}
    </div>

    <div class="mt-16 border-t border-slate-800 pt-12">
      <h2 class="text-xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        Start Here
      </h2>
      <p class="text-slate-400 text-sm leading-relaxed mb-6 max-w-2xl">
        If you're new to position sizing: read the Position Sizing guide first, then the Risk Management guide before moving on to funded accounts. If you're already trading a prop firm challenge, start with the Funded Accounts guide.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/" class="text-[10px] font-black uppercase tracking-widest text-emerald-500 border border-emerald-500/30 hover:border-emerald-500 hover:bg-emerald-500/10 px-4 py-2 rounded-full transition-all">
          Position Size Calculator →
        </a>
        <a href="/blog/" class="text-[10px] font-black uppercase tracking-widest text-slate-400 border border-slate-700 hover:border-slate-500 px-4 py-2 rounded-full transition-all">
          Analysis & Blog →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
