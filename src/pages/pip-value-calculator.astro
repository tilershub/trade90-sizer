---
import BaseLayout from '../layouts/BaseLayout.astro';

const seoTitle = "Pip Value Calculator — Forex Pip Value Per Lot (2024)";
const seoDescription = "Free forex pip value calculator. Find the exact pip value in USD for EUR/USD, GBP/USD, USD/JPY, Gold (XAU/USD), NAS100 and 45+ instruments. Formula, table and examples included.";
const keywords = [
  "pip value calculator",
  "forex pip value",
  "pip value per lot",
  "pip value in dollars",
  "how to calculate pip value",
  "pip value eurusd",
  "pip value gold xauusd",
  "pip value usdjpy",
  "what is pip value in forex",
  "pip calculator",
];

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

// Pip value reference table data
const pipTable = [
  { pair: 'EUR/USD', pip: '0.0001', standard: '$10.00', mini: '$1.00', micro: '$0.10', note: 'Fixed — USD-quoted' },
  { pair: 'GBP/USD', pip: '0.0001', standard: '$10.00', mini: '$1.00', micro: '$0.10', note: 'Fixed — USD-quoted' },
  { pair: 'AUD/USD', pip: '0.0001', standard: '$10.00', mini: '$1.00', micro: '$0.10', note: 'Fixed — USD-quoted' },
  { pair: 'NZD/USD', pip: '0.0001', standard: '$10.00', mini: '$1.00', micro: '$0.10', note: 'Fixed — USD-quoted' },
  { pair: 'USD/JPY', pip: '0.01',   standard: '~$6.70', mini: '~$0.67', micro: '~$0.07', note: 'Varies with rate' },
  { pair: 'USD/CHF', pip: '0.0001', standard: '~$10.50', mini: '~$1.05', micro: '~$0.11', note: 'Varies with CHF/USD' },
  { pair: 'USD/CAD', pip: '0.0001', standard: '~$7.50', mini: '~$0.75', micro: '~$0.08', note: 'Varies with CAD/USD' },
  { pair: 'EUR/GBP', pip: '0.0001', standard: '~$12.50', mini: '~$1.25', micro: '~$0.13', note: 'Varies with GBP/USD' },
  { pair: 'GBP/JPY', pip: '0.01',   standard: '~$6.70', mini: '~$0.67', micro: '~$0.07', note: 'Varies with rate' },
  { pair: 'Gold (XAU/USD)', pip: '0.1', standard: '$10.00', mini: '$1.00', micro: '$0.10', note: '1 pip = $0.10 on gold price' },
  { pair: 'Silver (XAG/USD)', pip: '0.001', standard: '$5.00', mini: '$0.50', micro: '$0.05', note: '1 pip = $0.001' },
  { pair: 'NAS100', pip: '1.0', standard: '~$1.00', mini: '~$0.10', micro: '~$0.01', note: 'Per point — broker varies' },
  { pair: 'US30 (Dow Jones)', pip: '1.0', standard: '~$1.00', mini: '~$0.10', micro: '~$0.01', note: 'Per point — broker varies' },
  { pair: 'SPX500 (S&P 500)', pip: '0.1', standard: '~$1.00', mini: '~$0.10', micro: '~$0.01', note: 'Per point — broker varies' },
  { pair: 'BTC/USD', pip: '1.0', standard: '~$1.00', mini: '~$0.10', micro: '~$0.01', note: 'Per $1 BTC move — varies' },
  { pair: 'ETH/USD', pip: '0.1', standard: '~$0.10', mini: '~$0.01', micro: '~$0.001', note: 'Broker contract varies' },
  { pair: 'WTI Oil (USOIL)', pip: '0.01', standard: '~$1.00', mini: '~$0.10', micro: '~$0.01', note: 'Per cent per barrel' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is pip value in forex?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pip value is the dollar amount gained or lost for a one-pip move on a specific lot size. For EUR/USD on a standard lot (100,000 units), 1 pip = $10. For a mini lot (10,000 units), 1 pip = $1. Pip value determines how much money you risk per pip when setting a stop loss.",
      },
    },
    {
      "@type": "Question",
      name: "How do you calculate pip value?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pip Value = (Pip Size / Exchange Rate) × Lot Size. For USD-quoted pairs like EUR/USD: Pip Value = (0.0001 / 1.0) × 100,000 = $10 per standard lot. For JPY-quoted pairs like USD/JPY at 149.50: Pip Value = (0.01 / 149.50) × 100,000 = $6.69 per standard lot.",
      },
    },
    {
      "@type": "Question",
      name: "What is the pip value of gold (XAU/USD)?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Gold (XAU/USD) has a pip size of $0.10 (1 pip = $0.10 price movement). On a standard lot of 100 troy ounces, the pip value is $10 per pip (100 oz × $0.10). A $1 move on gold = 10 pips = $100 profit or loss on a standard lot.",
      },
    },
    {
      "@type": "Question",
      name: "Why does pip value matter for position sizing?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pip value directly determines your position size. To risk $100 on a 30-pip stop, you need: $100 ÷ (30 pips × $10 pip value) = 0.33 lots on EUR/USD. If you don't know the pip value, you can't calculate the correct lot size and risk more or less than intended.",
      },
    },
    {
      "@type": "Question",
      name: "Does pip value change?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "For USD-quoted pairs (EUR/USD, GBP/USD, AUD/USD), pip value is fixed at $10 per standard lot. For USD-base pairs like USD/JPY and USD/CHF, the pip value fluctuates with the exchange rate. Gold and commodities also have variable pip values when priced against a non-USD base.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Pip Value Calculator", item: canonicalURL },
  ],
};

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Forex Pip Value Calculator",
  description: seoDescription,
  url: canonicalURL,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  creator: { "@type": "Organization", name: "TRADE90", url: site },
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="py-14 px-4 border-b border-slate-800/50 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-300">Pip Value Calculator</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-4">
        Forex <span class="text-emerald-400">Pip Value</span> Calculator
      </h1>
      <p class="text-slate-300 text-base leading-relaxed max-w-2xl mb-8">
        The pip value determines how much money you gain or lose per pip move on any trade. Use the reference table below to find the pip value for EUR/USD, Gold, NAS100, GBP/JPY, and 45+ instruments in seconds.
      </p>

      <!-- Quick formula -->
      <div class="bg-slate-900 border border-emerald-500/20 rounded-2xl p-6">
        <h2 class="text-emerald-400 font-black uppercase text-xs tracking-widest mb-4">Pip Value Formula</h2>
        <div class="font-mono text-sm text-slate-200 space-y-2">
          <p><span class="text-slate-500">USD-quoted pairs (EUR/USD, GBP/USD):</span>  Pip Value = Pip Size × Lot Size</p>
          <p><span class="text-slate-500">USD-base pairs (USD/JPY, USD/CHF):    </span>  Pip Value = (Pip Size / Exchange Rate) × Lot Size</p>
          <p><span class="text-slate-500">Cross pairs (EUR/GBP, GBP/JPY):       </span>  Pip Value = Pip Size × Lot Size × (Quote/USD Rate)</p>
        </div>
        <div class="mt-4 grid sm:grid-cols-2 gap-4 text-xs">
          <div class="bg-slate-950 rounded-xl p-3">
            <p class="text-emerald-400 font-black uppercase tracking-widest mb-1">EUR/USD Example</p>
            <p class="text-slate-300 font-mono">(0.0001 / 1.0) × 100,000 = <strong class="text-white">$10.00/pip</strong></p>
          </div>
          <div class="bg-slate-950 rounded-xl p-3">
            <p class="text-emerald-400 font-black uppercase tracking-widest mb-1">USD/JPY Example (at 149.50)</p>
            <p class="text-slate-300 font-mono">(0.01 / 149.50) × 100,000 = <strong class="text-white">~$6.69/pip</strong></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pip Value Reference Table ─────────────────────────────── -->
  <section class="max-w-5xl mx-auto py-16 px-6">
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
      Pip Value Reference Table
    </h2>
    <p class="text-slate-400 text-sm mb-8 leading-relaxed max-w-2xl">
      Pip values below are for a USD-denominated account. Values for non-USD-quoted instruments fluctuate with exchange rates — approximate values shown.
    </p>

    <div class="overflow-x-auto rounded-2xl border border-slate-800">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-900/80 border-b border-slate-800">
            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-emerald-400">Instrument</th>
            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-emerald-400">Pip Size</th>
            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-emerald-400">Standard Lot</th>
            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-emerald-400">Mini Lot (0.1)</th>
            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-emerald-400">Micro Lot (0.01)</th>
            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Note</th>
          </tr>
        </thead>
        <tbody>
          {pipTable.map(({ pair, pip, standard, mini, micro, note }, i) => (
            <tr class={`border-b border-slate-800/50 ${i % 2 === 0 ? '' : 'bg-slate-900/20'}`}>
              <td class="px-5 py-3 font-bold text-white">{pair}</td>
              <td class="px-5 py-3 font-mono text-slate-300">{pip}</td>
              <td class="px-5 py-3 font-mono font-bold text-emerald-400">{standard}</td>
              <td class="px-5 py-3 font-mono text-slate-300">{mini}</td>
              <td class="px-5 py-3 font-mono text-slate-500">{micro}</td>
              <td class="px-5 py-3 text-[10px] text-slate-600">{note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── How pip value affects position size ────────────────────── -->
  <section class="max-w-5xl mx-auto pb-16 px-6">
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
      How Pip Value Affects Your Lot Size
    </h2>
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="space-y-4 text-slate-400 text-sm leading-relaxed">
        <p>
          Pip value is the bridge between your stop loss distance and your lot size. Without it, you cannot calculate position size accurately — you'll risk either too much or too little on every trade.
        </p>
        <p>
          For USD-quoted pairs (EUR/USD, GBP/USD, AUD/USD), pip value is a fixed $10 per standard lot regardless of the exchange rate. This makes position sizing straightforward.
        </p>
        <p>
          For USD-base pairs like USD/JPY, the pip value changes daily as the exchange rate moves. At USD/JPY 149.50, a standard lot earns ~$6.69 per pip. At 110.00, it earns ~$9.09 per pip. The TRADE90 calculator applies the current live rate automatically.
        </p>
      </div>
      <div>
        <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-4">
          Same Stop Loss, Different Pip Values → Different Lot Sizes
        </h3>
        <div class="bg-slate-900 rounded-2xl overflow-hidden border border-slate-800">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-slate-700">
                <th class="px-4 py-2.5 text-left text-emerald-400 font-black uppercase tracking-widest">Pair</th>
                <th class="px-4 py-2.5 text-left text-emerald-400 font-black uppercase tracking-widest">30-pip SL</th>
                <th class="px-4 py-2.5 text-left text-emerald-400 font-black uppercase tracking-widest">Lot Size*</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['EUR/USD', '$10/pip', '0.33 lots'],
                ['GBP/USD', '$10/pip', '0.33 lots'],
                ['USD/JPY', '~$6.70/pip', '~0.50 lots'],
                ['USD/CHF', '~$10.50/pip', '~0.32 lots'],
                ['EUR/GBP', '~$12.50/pip', '~0.27 lots'],
                ['GBP/JPY', '~$6.70/pip', '~0.50 lots'],
              ].map(([pair, pipV, lot], i) => (
                <tr class={`border-b border-slate-800/50 ${i % 2 ? 'bg-slate-900/30' : ''}`}>
                  <td class="px-4 py-2.5 font-bold text-white">{pair}</td>
                  <td class="px-4 py-2.5 font-mono text-slate-300">{pipV}</td>
                  <td class="px-4 py-2.5 font-mono text-emerald-400 font-bold">{lot}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="px-4 py-2 text-[10px] text-slate-600">*$10,000 account, 1% risk ($100), 30-pip stop</p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-slate-900/70 border border-emerald-500/20 rounded-2xl p-6">
      <h3 class="text-white font-black uppercase tracking-tighter text-lg mb-2">
        Calculate Your Position Size Now
      </h3>
      <p class="text-slate-400 text-sm mb-5">
        The TRADE90 position size calculator automatically applies the correct pip value for every instrument. Enter your balance, risk %, and stop loss to get the exact lot size.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-black uppercase tracking-widest px-5 py-2.5 rounded-xl transition-colors">
          Open Position Sizer →
        </a>
        <a href="/calculator/" class="inline-flex items-center gap-2 border border-slate-700 hover:border-emerald-500/50 text-slate-300 text-xs font-black uppercase tracking-widest px-5 py-2.5 rounded-xl transition-colors">
          All 45+ Instruments
        </a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto pb-20 px-6">
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
      Pip Value FAQ
    </h2>
    <div class="space-y-3">
      {[
        {
          q: "What is pip value in forex?",
          a: "Pip value is the dollar amount gained or lost for a one-pip move on a specific lot size. For EUR/USD on a standard lot, 1 pip = $10. For a mini lot, 1 pip = $1. Knowing pip value is essential for calculating position size and managing risk correctly.",
        },
        {
          q: "How do you calculate pip value?",
          a: "For USD-quoted pairs: Pip Value = Pip Size × Lot Size. For EUR/USD standard lot: 0.0001 × 100,000 = $10. For USD-base pairs: Pip Value = (Pip Size / Exchange Rate) × Lot Size. For USD/JPY at 149.50: (0.01 / 149.50) × 100,000 = $6.69.",
        },
        {
          q: "What is the pip value of gold (XAU/USD)?",
          a: "Gold's pip size is $0.10 (1 pip = $0.10 price move). A standard lot of gold is 100 troy ounces, so pip value = 100 × $0.10 = $10 per pip. A $1 move on gold = 10 pips = $100 profit or loss on one standard lot.",
        },
        {
          q: "Why does pip value matter for position sizing?",
          a: "Without knowing pip value, you can't calculate the correct lot size. To risk $100 on a 30-pip stop on EUR/USD: $100 ÷ (30 × $10) = 0.33 lots. On USD/JPY with $6.70 pip value: $100 ÷ (30 × $6.70) = 0.50 lots. The same stop in pips costs different dollar amounts depending on the pair.",
        },
        {
          q: "Does pip value change?",
          a: "For USD-quoted pairs (EUR/USD, GBP/USD, AUD/USD), pip value is a fixed $10 per standard lot. For USD-base pairs (USD/JPY, USD/CHF, USD/CAD), it fluctuates with the exchange rate. Cross pairs like EUR/GBP and GBP/JPY also have variable pip values. TRADE90's calculator applies the correct rate automatically.",
        },
      ].map(({ q, a }) => (
        <details class="group bg-slate-900/40 border border-slate-800 hover:border-emerald-500/30 rounded-2xl overflow-hidden transition-colors">
          <summary class="flex justify-between items-center p-5 cursor-pointer font-bold text-slate-200 text-sm uppercase tracking-tight hover:text-white list-none">
            {q}
            <span class="text-emerald-500 group-open:rotate-45 transition-transform text-xl leading-none shrink-0 ml-4">+</span>
          </summary>
          <div class="px-5 pb-5 text-slate-400 text-sm leading-relaxed border-t border-slate-800/50 pt-4">
            {a}
          </div>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
