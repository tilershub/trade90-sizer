---
import BaseLayout from '../layouts/BaseLayout.astro';
import PositionSizer from '../components/PositionSizer.svelte';
import BlogCard from '../components/BlogCard.astro';
import FtmoCta from '../components/FtmoCta.astro';
import { getPosts } from '../lib/blog';
import { getSlug } from '../lib/instruments';

const posts = await getPosts({ limit: 3 });

const seoTitle = "Position Size Calculator for Funded Traders — Trade90 Safety System";
const seoDescription = "Calculate the exact lot size for every trade. Enforces the 0.5% per-trade limit and 1% daily risk target. Works for FTMO, E8, Apex, Topstep, and all prop firm challenges. Free, no login.";
const keywords = [
  "position size calculator funded traders",
  "funded trader risk calculator",
  "prop firm position sizing calculator",
  "ftmo position size calculator",
  "funded account lot size calculator",
  "forex position size calculator",
  "lot size calculator prop firm",
  "funded trader risk management",
  "prop firm challenge calculator",
];

const site = Astro.site?.toString() || "https://tradeninety.com";

const featuredCalcs = [
  { symbol: 'XAUUSD',  name: 'Gold (XAU/USD)',   label: '#1 Funded Instrument' },
  { symbol: 'NAS100',  name: 'NAS100',            label: 'US Tech Index' },
  { symbol: 'EURUSD',  name: 'EUR/USD',           label: 'Most Liquid Pair' },
  { symbol: 'US30',    name: 'Dow Jones (US30)',  label: 'US Indices' },
  { symbol: 'GBPUSD',  name: 'GBP/USD',          label: 'High Volatility' },
  { symbol: 'SPX500',  name: 'S&P 500',           label: 'Broad Market' },
  { symbol: 'BTCUSD',  name: 'Bitcoin',           label: 'Crypto' },
  { symbol: 'GER40',   name: 'GER40 (DAX)',       label: 'European Index' },
];

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 Position Size Calculator for Funded Traders",
  description: seoDescription,
  url: site,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "Funded Account mode with Trade90 Safety System (0.5% per trade, 1% daily)",
    "Real Account mode with flexible risk guidance",
    "Risk state display: Safe, Caution, Aggressive, Dangerous",
    "Daily risk budget tracker with safe trades remaining",
    "45+ instruments: Forex, Gold, Indices, Crypto, Commodities",
  ],
  creator: { "@type": "Organization", name: "TRADE90", url: site },
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />

  <!-- ── Hero + Calculator ────────────────────────────────────────────────── -->
  <section class="relative py-14 px-4 border-b border-slate-900/50 overflow-hidden bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/15 via-slate-950 to-slate-950">
    <div class="max-w-2xl mx-auto text-center">

      <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/25 rounded-full px-4 py-1.5 mb-6">
        <svg class="text-emerald-400 w-3.5 h-3.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="text-emerald-400 text-[10px] font-black uppercase tracking-[0.25em]">Trade90 Safety System — Built for Funded Traders</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-4 leading-[0.9]">
        Position Size<br/><span class="text-emerald-400">Calculator</span><br/>for Funded Traders
      </h1>

      <p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">
        Enter your account balance, risk %, and stop loss — get the exact lot size instantly. Enforces <strong class="text-white">0.5% per trade</strong> and <strong class="text-white">1% daily</strong> limits for funded account challenges.
      </p>

      <!-- Calculator -->
      <div class="bg-slate-900/40 rounded-[2.5rem] border border-slate-800/50 p-2 shadow-2xl backdrop-blur-sm transition-all hover:border-emerald-500/20">
        <noscript>
          <div class="p-6 text-center">
            <p class="text-slate-300 text-sm font-bold mb-3">Enable JavaScript to use the interactive calculator.</p>
            <p class="text-slate-400 text-sm">Formula: <strong class="text-white">Lot Size = (Balance × Risk%) ÷ (SL Pips × Pip Value)</strong></p>
            <p class="text-slate-400 text-xs mt-2">Example: $100,000 × 0.5% ÷ (25 pips × $10) = <strong class="text-emerald-400">2.00 lots</strong> on EUR/USD</p>
          </div>
        </noscript>
        <PositionSizer client:idle />
      </div>

      <!-- Proof bar -->
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mt-8 text-[10px] font-black uppercase tracking-widest text-slate-500">
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>FTMO</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Apex</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Topstep</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>E8</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>45+ Instruments</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Free Forever</span>
      </div>

      <!-- Quick instrument links -->
      <div class="mt-8">
        <p class="text-[10px] uppercase tracking-widest text-slate-600 font-bold mb-3">Dedicated Calculators</p>
        <div class="flex flex-wrap justify-center gap-2">
          {[
            ['Gold',    '/calculator/xauusd/'],
            ['NAS100',  '/calculator/nas100/'],
            ['EUR/USD', '/calculator/eurusd/'],
            ['US30',    '/calculator/us30/'],
            ['BTC/USD', '/calculator/btcusd/'],
            ['GBP/USD', '/calculator/gbpusd/'],
          ].map(([label, href]) => (
            <a href={href} class="text-[10px] font-black uppercase tracking-widest text-emerald-500 border border-emerald-500/30 hover:border-emerald-500 hover:bg-emerald-500/10 px-3 py-1.5 rounded-full transition-all">
              {label}
            </a>
          ))}
          <a href="/calculator/" class="text-[10px] font-black uppercase tracking-widest text-slate-400 border border-slate-700 hover:border-slate-500 px-3 py-1.5 rounded-full transition-all">
            All 45+ →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How It Works ──────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto py-16 px-6">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-2">How It Works</h2>
      <p class="text-slate-500 text-xs uppercase tracking-widest font-bold">Three inputs. One answer. No guessing.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          n: "01",
          title: "Select Your Instrument",
          body: "Choose from 45+ instruments — major forex pairs, gold, silver, US and European indices, and crypto. Pip values are pre-configured for each.",
        },
        {
          n: "02",
          title: "Set Your Stop Loss",
          body: "Enter your entry price and stop loss level. The calculator measures the distance and converts it to dollars automatically using the correct pip value.",
        },
        {
          n: "03",
          title: "Get Your Lot Size",
          body: "See your exact lot size, dollar risk, and R:R ratio. The risk state tells you if this trade is Safe, Caution, Aggressive, or Dangerous for a funded account.",
        },
      ].map(({ n, title, body }) => (
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
          <div class="text-4xl font-black text-emerald-500/20 mb-3">{n}</div>
          <h3 class="text-white font-black uppercase text-sm tracking-tight mb-2">{title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Instruments Grid ──────────────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto py-6 px-6 border-t border-slate-900/50">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-black uppercase tracking-tighter text-white border-l-4 border-emerald-500 pl-4">
          Instruments
        </h2>
        <p class="text-slate-500 text-[10px] uppercase tracking-widest font-bold pl-5 mt-1">
          Dedicated calculators with pre-configured pip values
        </p>
      </div>
      <a href="/calculator/" class="text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors">
        All 45+ →
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {featuredCalcs.map(({ symbol, name, label }) => (
        <a
          href={`/calculator/${getSlug(symbol)}/`}
          class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-4 transition-all hover:-translate-y-0.5"
        >
          <div class="text-emerald-400 font-black text-sm tracking-tight group-hover:text-emerald-300 mb-1 truncate">{name}</div>
          <div class="text-slate-600 text-[9px] uppercase tracking-widest font-bold">{label}</div>
          <div class="mt-2 text-[9px] text-slate-700 group-hover:text-emerald-500/60 uppercase tracking-widest font-bold transition-colors">
            Calculate →
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Learn Hub ─────────────────────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto py-16 px-6 border-t border-slate-900/50">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-black uppercase tracking-tighter text-white border-l-4 border-emerald-500 pl-4">
          Learn
        </h2>
        <p class="text-slate-500 text-[10px] uppercase tracking-widest font-bold pl-5 mt-1">
          Three guides. One topic each. No repetition.
        </p>
      </div>
      <a href="/learn/" class="text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors">
        All Guides →
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      {[
        {
          href: "/learn/position-sizing/",
          tag: "Foundation",
          title: "Position Sizing: The Complete Guide",
          desc: "The formula, pip values by instrument, worked examples, and mistakes that blow accounts.",
        },
        {
          href: "/learn/risk-management/",
          tag: "Framework",
          title: "Risk Management for Funded Traders",
          desc: "The 0.5% rule, daily limits, drawdown survival tables, and the four-rule framework.",
        },
        {
          href: "/learn/funded-accounts/",
          tag: "Prop Firms",
          title: "Funded Account Trading Guide",
          desc: "Challenge rules, FTMO account sizes, comparison table, and passing strategy.",
        },
      ].map(({ href, tag, title, desc }) => (
        <a href={href} class="group block bg-slate-900/40 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-5 transition-all">
          <p class="text-[9px] font-black uppercase tracking-widest text-emerald-500 mb-1">{tag}</p>
          <h3 class="text-white font-black uppercase tracking-tighter text-sm mb-2 group-hover:text-emerald-400 transition-colors">{title}</h3>
          <p class="text-slate-400 text-xs leading-relaxed">{desc}</p>
          <span class="mt-3 inline-block text-[10px] font-black uppercase tracking-widest text-emerald-500">Read →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── FTMO Affiliate CTA ───────────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto pb-10 px-6">
    <FtmoCta variant="banner" />
  </section>

  <!-- ── Latest Analysis ───────────────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto pb-20 px-6 border-t border-slate-900/50 pt-16">
    <div class="flex items-center justify-between mb-10">
      <header>
        <h2 class="text-xl font-black border-l-4 border-emerald-500 pl-4 uppercase tracking-tighter text-slate-200">
          Latest Analysis
        </h2>
        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest pl-5 mt-1">
          Market breakdowns for funded traders
        </p>
      </header>
      <a href="/blog/" class="group flex items-center gap-2 text-[10px] font-black text-emerald-500 uppercase tracking-widest hover:text-white transition-all">
        All Posts <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <BlogCard
            title={post.title}
            excerpt={post.excerpt ?? ''}
            image={post.feature_image ?? undefined}
            slug={post.slug}
            date={post.published_at}
            readingTime={post.reading_time ?? undefined}
            tags={post.tags}
            index={i}
          />
        ))}
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { href: '/blog/best-prop-firms-us-traders-2026/', title: 'Best Prop Firms for US Traders 2026', desc: 'Which firms accept American traders and how to pass with the 1% rule.' },
          { href: '/blog/how-to-pass-funded-account-challenge/', title: 'How to Pass a Funded Challenge', desc: 'The volatility-adjusted risk blueprint — 0.5% rule, ADR calibration, daily limits.' },
          { href: '/blog/gold-lot-size-calculator-guide/', title: 'Gold Lot Size Calculator Guide', desc: 'XAU/USD pip value, common stop distances, and worked examples for funded traders.' },
        ].map(({ href, title, desc }) => (
          <a href={href} class="group block bg-slate-900/40 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 transition-all">
            <h3 class="text-white font-black uppercase tracking-tighter text-base mb-2 group-hover:text-emerald-400 transition-colors">{title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{desc}</p>
            <span class="mt-4 inline-block text-[10px] font-black uppercase tracking-widest text-emerald-500">Read →</span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
