---
import BaseLayout from '../layouts/BaseLayout.astro';
import PositionSizer from '../components/PositionSizer.svelte';
import BlogCard from '../components/BlogCard.astro';
import FAQ from '../components/FAQ.astro';
import { ghostClient } from '../lib/ghost';

const posts = await ghostClient.posts.browse({
  limit: 6,
  include: ['tags']
}).catch((err) => {
  console.error("Ghost Fetch Error:", err);
  return [];
});

const seoTitle = "Position Size Calculator — Forex, Gold & Crypto";
const seoDescription = "Free position size calculator for Forex, Gold, Indices and Crypto. Enter your account balance, risk %, stop loss and take profit to get the exact lot size instantly. Built by a veteran FTMO-funded trader.";
const site = Astro.site?.toString() || "https://tradeninety.com";

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 Position Size Calculator",
  description: seoDescription,
  url: site,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "Multi-asset support: Forex, Metals, Indices, Crypto, Commodities",
    "60+ trading pairs including EUR/USD, XAU/USD, BTC/USD",
    "Automatic pip value calculation for all asset types",
    "R:R ratio output",
    "Stop loss and take profit in pips",
  ],
  creator: {
    "@type": "Organization",
    name: "TRADE90",
    url: site,
  },
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={["position size calculator", "lot size calculator", "forex position calculator", "gold lot size calculator", "crypto position sizer", "ftmo position calculator", "risk management trading", "stop loss calculator"]}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />

  <section class="py-12 px-4 border-b border-slate-900/50 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-center text-3xl md:text-5xl font-black uppercase tracking-tighter text-white mb-2">
        Position Size <span class="text-emerald-400">Calculator</span>
      </h1>
      <p class="text-center text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-6">
        Forex, Gold &amp; Crypto — Free Lot Size Tool
      </p>

      <div class="bg-slate-900/40 rounded-[2.5rem] border border-slate-800/50 p-2 shadow-2xl backdrop-blur-sm transition-all hover:border-emerald-500/20">
        <noscript>
          <p class="p-6 text-sm text-slate-400">
            Enable JavaScript to use the Position Sizer.
          </p>
        </noscript>

        <PositionSizer client:idle />
      </div>

      <!-- Quick links to per-instrument pages -->
      <div class="mt-8 text-center">
        <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-3">Dedicated calculators</p>
        <div class="flex flex-wrap justify-center gap-2">
          {[
            ['EUR/USD', '/calculator/eurusd/'],
            ['Gold', '/calculator/xauusd/'],
            ['GBP/USD', '/calculator/gbpusd/'],
            ['NAS100', '/calculator/nas100/'],
            ['BTC/USD', '/calculator/btcusd/'],
            ['USD/JPY', '/calculator/usdjpy/'],
          ].map(([label, href]) => (
            <a href={href} class="text-[10px] font-black uppercase tracking-widest text-emerald-500 border border-emerald-500/30 hover:border-emerald-500 hover:bg-emerald-500/10 px-3 py-1.5 rounded-full transition-all">
              {label}
            </a>
          ))}
          <a href="/calculator/" class="text-[10px] font-black uppercase tracking-widest text-slate-400 border border-slate-700 hover:border-slate-500 px-3 py-1.5 rounded-full transition-all">
            All 45+ →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto py-20 px-6">
    <div class="flex items-center justify-between mb-12">
      <header class="space-y-1">
        <h2 class="text-xl font-black border-l-4 border-emerald-500 pl-4 uppercase tracking-tighter text-slate-200">
          Latest Market Analysis
        </h2>
        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest pl-5">
          Volatility & Trend Reports
        </p>
      </header>

      <nav>
        <a href="/blog" class="group flex items-center gap-2 text-[10px] font-black text-emerald-500 uppercase tracking-widest hover:text-white transition-all">
          Explore All <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </nav>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {posts.length > 0 ? posts.map((post, i) => (
        <article class="transition-transform duration-300 hover:-translate-y-1">
          <BlogCard
            title={post.title}
            excerpt={post.excerpt}
            image={post.feature_image}
            slug={post.slug}
            date={post.published_at}
            index={i}
          />
        </article>
      )) : (
        <div class="col-span-full py-20 text-center border border-dashed border-slate-800 rounded-3xl bg-slate-900/10">
          <p class="text-slate-600 italic text-sm font-medium">
            Synchronizing with TRADE90 Intelligence... Check back shortly.
          </p>
        </div>
      )}
    </div>
  </section>

  <FAQ showSchema={true} />

</BaseLayout>
