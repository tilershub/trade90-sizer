---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { HUB_ORDER, HUBS } from '../lib/hubs';

const seoTitle = "TRADE90 — Become a Consistently Funded Trader";
const seoDescription = "Master risk management, trading psychology, and disciplined execution with practical education, professional tools, and prop firm resources. Built for funded traders.";

const site = Astro.site?.toString() || "https://tradeninety.com";

// Featured guides — a curated cross-hub selection of the strongest articles
const featuredSlugs = [
  'psychology/why-traders-fail',
  'risk-management/risk-of-ruin',
  'trading-plans/how-to-build-a-trading-plan',
  'prop-firms/prop-firm-rules-explained',
  'performance/trading-journal-guide',
  'psychology/revenge-trading',
];
const allArticles = await getCollection('articles');
const byId = new Map(allArticles.map((a) => [a.id.replace(/\.mdx?$/, ''), a]));
const featured = featuredSlugs.map((s) => byId.get(s)).filter(Boolean);

// Learning paths — the five hubs plus the position sizing foundation guide
const learningPaths = [
  { href: '/psychology/', name: 'Trading Psychology', desc: 'Discipline, losing streaks, and emotional control.', accent: 'text-sky-400', ring: 'hover:border-sky-500/40' },
  { href: '/risk-management/', name: 'Risk Management', desc: 'Position sizing, daily limits, and drawdown.', accent: 'text-emerald-400', ring: 'hover:border-emerald-500/40' },
  { href: '/trading-plans/', name: 'Trading Plans', desc: 'Written plans, routines, and instrument frameworks.', accent: 'text-amber-400', ring: 'hover:border-amber-500/40' },
  { href: '/prop-firms/', name: 'Prop Firms', desc: 'Evaluations, rules, and funded accounts.', accent: 'text-purple-400', ring: 'hover:border-purple-500/40' },
  { href: '/performance/', name: 'Performance', desc: 'Journals, expectancy, and monthly reviews.', accent: 'text-rose-400', ring: 'hover:border-rose-500/40' },
  { href: '/risk-management/position-sizing/', name: 'Position Sizing Guide', desc: 'Start here — the foundation of it all.', accent: 'text-emerald-400', ring: 'hover:border-emerald-500/40' },
];

const tools = [
  { href: '/tools/position-size-calculator/', name: 'Position Size' },
  { href: '/risk-reward-calculator/', name: 'Risk / Reward' },
  { href: '/tools/drawdown-calculator/', name: 'Drawdown' },
  { href: '/pip-value-calculator/', name: 'Pip Value' },
  { href: '/tools/profit-calculator/', name: 'Profit / Loss' },
  { href: '/tools/compounding-calculator/', name: 'Compounding' },
];

const propFirmResources = [
  { href: '/prop-firms/prop-firm-rules-explained/', name: 'Prop Firm Rules Explained', desc: 'Every rule type and what triggers a breach.' },
  { href: '/prop-firms/how-to-choose-a-prop-firm/', name: 'How to Choose a Prop Firm', desc: 'A calm decision framework — drawdown model first.' },
  { href: '/prop-firms/ftmo-vs-fundednext/', name: 'FTMO vs FundedNext', desc: 'A balanced structural comparison.' },
  { href: '/prop-firms/', name: 'Prop Firm Hub', desc: 'Challenge mechanics, firm comparison, funded-account management.' },
];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "TRADE90",
  url: site,
  description: seoDescription,
};
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} slot="head-extra" />

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="relative py-24 md:py-32 px-6 border-b border-slate-900/60 overflow-hidden bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/12 via-slate-950 to-slate-950">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-slate-900/60 border border-slate-800 rounded-full px-4 py-1.5 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-slate-400 text-[10px] font-black uppercase tracking-[0.25em]">Education · Tools · Prop Firm Resources</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-black tracking-tighter text-white mb-6 leading-[0.95]">
        Become a Consistently<br/><span class="text-emerald-400">Funded Trader</span>
      </h1>

      <p class="text-slate-400 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        Master risk management, trading psychology, and disciplined execution — with practical education, professional tools, and honest prop firm resources.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/risk-management/position-sizing/" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-sm px-8 py-4 rounded-xl transition-colors">
          Start Learning →
        </a>
        <a href="/tools/" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-slate-700 hover:border-emerald-500/50 text-slate-200 font-black uppercase tracking-widest text-sm px-8 py-4 rounded-xl transition-colors">
          Explore Tools
        </a>
      </div>
    </div>
  </section>

  <!-- ── Learning Paths ───────────────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto py-20 px-6">
    <div class="text-center mb-12">
      <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">Learning Paths</p>
      <h2 class="text-3xl font-black uppercase tracking-tighter text-white mb-3">Where Do You Want to Improve?</h2>
      <p class="text-slate-400 text-sm max-w-xl mx-auto leading-relaxed">
        Five knowledge hubs covering the full discipline of funded trading. Each is a structured path, not a pile of articles.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {learningPaths.map(({ href, name, desc, accent, ring }) => (
        <a href={href} class={`group block bg-slate-900/40 border border-slate-800 ${ring} rounded-2xl p-6 transition-all hover:-translate-y-0.5`}>
          <h3 class={`font-black uppercase tracking-tighter text-base mb-2 ${accent}`}>{name}</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">{desc}</p>
          <span class="text-[10px] font-black uppercase tracking-widest text-slate-500 group-hover:text-emerald-400 transition-colors">Explore →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── The Funded Trader Workflow ───────────────────────────────────────── -->
  <section class="border-y border-slate-900/60 bg-slate-950/40">
    <div class="max-w-5xl mx-auto py-16 px-6">
      <div class="text-center mb-10">
        <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">The Platform</p>
        <h2 class="text-3xl font-black uppercase tracking-tighter text-white mb-3">Your Daily Workflow</h2>
        <p class="text-slate-400 text-sm max-w-xl mx-auto leading-relaxed">
          Not just articles — a working system. Prepare with a written plan, run your day from one dashboard, and review with real statistics. Free, private, no login.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          {
            href: '/tools/trading-plan-builder/',
            step: 'Prepare',
            name: 'Trading Plan Builder',
            desc: 'Write the six sections of a complete plan — saved in your browser, exported to a file.',
          },
          {
            href: '/today/',
            step: 'Trade',
            name: "Today's Dashboard",
            desc: 'Session clock, daily risk budget, and your pre/in/post-session checklist. The first tab of the day.',
          },
          {
            href: '/journal/',
            step: 'Review',
            name: 'Trading Journal',
            desc: 'Log trades in R-multiples and watch win rate, expectancy, and plan adherence build.',
          },
        ].map(({ href, step, name, desc }, i) => (
          <a href={href} class="group relative block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 transition-all hover:-translate-y-0.5">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-7 h-7 rounded-lg bg-emerald-500/10 border border-emerald-500/25 flex items-center justify-center text-emerald-400 font-black text-xs">{i + 1}</span>
              <span class="text-[9px] font-black uppercase tracking-[0.3em] text-emerald-500">{step}</span>
            </div>
            <h3 class="text-white font-black uppercase tracking-tighter text-base mb-2 group-hover:text-emerald-400 transition-colors">{name}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{desc}</p>
            <span class="mt-4 inline-block text-[10px] font-black uppercase tracking-widest text-emerald-500">Open →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Featured Guides ──────────────────────────────────────────────────── -->
  <section>
    <div class="max-w-5xl mx-auto py-20 px-6">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">Featured Guides</p>
          <h2 class="text-3xl font-black uppercase tracking-tighter text-white">Read These First</h2>
        </div>
        <a href="/risk-management/" class="hidden sm:inline text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors">All Guides →</a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {featured.map((a) => {
          const path = a.id.replace(/\.mdx?$/, '');
          const hub = HUBS[a.data.hub];
          return (
            <a href={`/${path}/`} class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 transition-all">
              <div class="flex items-center justify-between mb-3">
                <span class={`text-[9px] font-black uppercase tracking-widest ${hub.accent}`}>{hub.shortName}</span>
                <span class="text-[9px] text-slate-600 font-bold uppercase tracking-widest">{a.data.reading_time} min</span>
              </div>
              <h3 class="text-white font-black uppercase tracking-tighter text-base mb-2 group-hover:text-emerald-400 transition-colors leading-snug">{a.data.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{a.data.description}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── Free Tools (after education) ─────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto py-20 px-6">
    <div class="text-center mb-12">
      <p class="text-[10px] font-black uppercase tracking-[0.35em] text-emerald-500 mb-3">Free Tools</p>
      <h2 class="text-3xl font-black uppercase tracking-tighter text-white mb-3">Professional Calculators</h2>
      <p class="text-slate-400 text-sm max-w-xl mx-auto leading-relaxed">
        Supporting tools, not the main event. Each one is paired with the guide that explains the concept behind it. No login required.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {tools.map(({ href, name }) => (
        <a href={href} class="group flex items-center justify-between bg-slate-900/40 border border-slate-800 hover:border-emerald-500/40 rounded-2xl px-5 py-4 transition-all">
          <span class="text-white font-black uppercase tracking-tighter text-sm group-hover:text-emerald-400 transition-colors">{name}</span>
          <span class="text-emerald-500 text-lg">→</span>
        </a>
      ))}
    </div>
    <p class="text-center mt-8">
      <a href="/tools/" class="text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors">All Tools &amp; 45+ Instrument Calculators →</a>
    </p>
  </section>

  <!-- ── Prop Firm Resources ──────────────────────────────────────────────── -->
  <section class="border-y border-slate-900/60 bg-slate-950/40">
    <div class="max-w-5xl mx-auto py-20 px-6">
      <div class="text-center mb-12">
        <p class="text-[10px] font-black uppercase tracking-[0.35em] text-purple-400 mb-3">Prop Firm Resources</p>
        <h2 class="text-3xl font-black uppercase tracking-tighter text-white mb-3">Understand the Rules Before You Pay</h2>
        <p class="text-slate-400 text-sm max-w-xl mx-auto leading-relaxed">
          Honest, education-first coverage of prop firm evaluations — reviews and comparisons without the hard sell.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        {propFirmResources.map(({ href, name, desc }) => (
          <a href={href} class="group block bg-slate-900/50 border border-slate-800 hover:border-purple-500/40 rounded-2xl p-6 transition-all">
            <h3 class="text-white font-black uppercase tracking-tighter text-base mb-2 group-hover:text-purple-300 transition-colors">{name}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Newsletter ───────────────────────────────────────────────────────── -->
  <Newsletter />
</BaseLayout>
