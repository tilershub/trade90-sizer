---
import BaseLayout from '../layouts/BaseLayout.astro';
import PositionSizer from '../components/PositionSizer.svelte';
import BlogCard from '../components/BlogCard.astro';
import { getPosts } from '../lib/blog';
import { getSlug } from '../lib/instruments';

const posts = await getPosts({ limit: 3 });

const seoTitle = "Free Forex Position Size Calculator — Lot Size & Risk Tool";
const seoDescription = "Calculate the exact lot size for any forex trade in seconds. Free position size calculator for EUR/USD, Gold, NAS100, BTC and 45+ instruments. Used by FTMO-funded and prop firm traders worldwide.";
const keywords = [
  "forex position size calculator",
  "lot size calculator forex",
  "position sizing calculator",
  "forex risk calculator",
  "lot size calculator",
  "how to calculate position size forex",
  "ftmo position size calculator",
  "prop firm lot size calculator",
  "gold position size calculator",
  "crypto lot size calculator",
];

const site = Astro.site?.toString() || "https://tradeninety.com";

const featuredCalcs = [
  { symbol: 'EURUSD',  name: 'EUR/USD',          label: 'Most Liquid Pair' },
  { symbol: 'XAUUSD',  name: 'Gold (XAU/USD)',   label: 'Metals' },
  { symbol: 'GBPUSD',  name: 'GBP/USD',          label: 'Cable' },
  { symbol: 'NAS100',  name: 'NAS100',            label: 'US Tech Index' },
  { symbol: 'BTCUSD',  name: 'Bitcoin',           label: 'Crypto' },
  { symbol: 'USDJPY',  name: 'USD/JPY',           label: 'Yen Pair' },
  { symbol: 'US30',    name: 'Dow Jones (US30)',  label: 'US Indices' },
  { symbol: 'GBPJPY',  name: 'GBP/JPY',          label: 'High Volatility' },
  { symbol: 'SPX500',  name: 'S&P 500',           label: 'Broad Market' },
  { symbol: 'ETHUSD',  name: 'Ethereum',          label: 'Crypto' },
  { symbol: 'XAGUSD',  name: 'Silver (XAG/USD)', label: 'Metals' },
  { symbol: 'USOIL',   name: 'WTI Crude Oil',    label: 'Commodities' },
];

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 Forex Position Size Calculator",
  description: seoDescription,
  url: site,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "45+ instruments: Forex, Gold, Indices, Crypto, Commodities",
    "Automatic pip value calculation for every asset class",
    "Lot size, risk amount, and R:R ratio output",
    "FTMO and prop firm challenge compatible",
    "Multi-currency account support (USD, GBP, EUR)",
  ],
  creator: { "@type": "Organization", name: "TRADE90", url: site },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is a forex position size calculator?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A forex position size calculator determines how many lots to trade based on your account balance, risk percentage, and stop loss distance. It prevents over-leveraging by computing the exact lot size so a losing trade costs exactly your planned risk amount — for example, 1% of a $10,000 account.",
      },
    },
    {
      "@type": "Question",
      name: "How do I calculate lot size in forex?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Lot Size = (Account Balance × Risk%) ÷ (Stop Loss in Pips × Pip Value per Lot). Example: $10,000 account, 1% risk ($100), 30-pip stop on EUR/USD (pip value $10/lot) = $100 ÷ (30 × $10) = 0.33 lots. The TRADE90 calculator handles all pip value conversions automatically.",
      },
    },
    {
      "@type": "Question",
      name: "What percentage should I risk per trade?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Most professional forex traders and FTMO-funded accounts risk 0.5%–1% per trade. Risking 2% is the absolute maximum most prop firms allow. At 1% risk, five consecutive losses only reduce your account by 4.9%, keeping you within challenge limits and psychologically stable.",
      },
    },
    {
      "@type": "Question",
      name: "What is a standard lot in forex?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A standard lot is 100,000 units of the base currency. On EUR/USD, 1 standard lot controls €100,000. A mini lot is 0.10 lots (10,000 units) and a micro lot is 0.01 lots (1,000 units). Position size calculators output in standard lots — 0.33 lots means 33,000 units.",
      },
    },
    {
      "@type": "Question",
      name: "How does FTMO position sizing work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "FTMO challenges set daily loss limits (4–5%) and max drawdown limits (8–10%). Sizing at 0.5%–1% per trade ensures even five consecutive losses stay within limits. Use your current challenge balance when calculating, as drawdown limits apply to real-time equity, not the starting balance.",
      },
    },
    {
      "@type": "Question",
      name: "Does position sizing differ for gold and index CFDs?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Gold (XAU/USD) has a pip value of $1 per standard lot per pip, where 1 pip = $0.01. A $10 move on gold equals 1,000 pips and $1,000 per standard lot. For NAS100 and US30, the value is per point and depends on broker contract size. The TRADE90 calculator pre-configures all values for every instrument.",
      },
    },
  ],
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />

  <!-- ── Hero + Calculator ───────────────────────────────────────── -->
  <section class="py-12 px-4 border-b border-slate-900/50 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-2xl mx-auto">
      <p class="text-center text-[10px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-3">
        Free Tool — No Sign-up Required
      </p>
      <h1 class="text-center text-3xl md:text-5xl font-black uppercase tracking-tighter text-white mb-3">
        Forex Position <span class="text-emerald-400">Size Calculator</span>
      </h1>
      <p class="text-center text-slate-400 text-sm leading-relaxed mb-8 max-w-xl mx-auto">
        Enter your account balance, risk %, and stop loss to get the exact lot size for any trade — Forex, Gold, Indices, or Crypto.
      </p>

      <div class="bg-slate-900/40 rounded-[2.5rem] border border-slate-800/50 p-2 shadow-2xl backdrop-blur-sm transition-all hover:border-emerald-500/20">
        <noscript>
          <div class="p-6 text-center">
            <p class="text-slate-300 text-sm font-bold mb-3">Enable JavaScript to use the interactive calculator.</p>
            <p class="text-slate-400 text-sm">Formula: <strong class="text-white">Lot Size = (Balance × Risk%) ÷ (SL Pips × Pip Value)</strong></p>
            <p class="text-slate-400 text-xs mt-2">Example: $10,000 × 1% ÷ (30 pips × $10) = <strong class="text-emerald-400">0.33 lots</strong> on EUR/USD</p>
          </div>
        </noscript>
        <PositionSizer client:idle />
      </div>

      <div class="mt-8 text-center">
        <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-3">Dedicated calculators</p>
        <div class="flex flex-wrap justify-center gap-2">
          {[
            ['EUR/USD', '/calculator/eurusd/'],
            ['Gold',    '/calculator/xauusd/'],
            ['GBP/USD', '/calculator/gbpusd/'],
            ['NAS100',  '/calculator/nas100/'],
            ['BTC/USD', '/calculator/btcusd/'],
            ['USD/JPY', '/calculator/usdjpy/'],
          ].map(([label, href]) => (
            <a href={href} class="text-[10px] font-black uppercase tracking-widest text-emerald-500 border border-emerald-500/30 hover:border-emerald-500 hover:bg-emerald-500/10 px-3 py-1.5 rounded-full transition-all">
              {label}
            </a>
          ))}
          <a href="/calculator/" class="text-[10px] font-black uppercase tracking-widest text-slate-400 border border-slate-700 hover:border-slate-500 px-3 py-1.5 rounded-full transition-all">
            All 45+ →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How to Calculate Position Size ─────────────────────────── -->
  <section class="max-w-5xl mx-auto py-20 px-6" id="how-to-calculate">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-black uppercase tracking-tighter text-white mb-3">
        How to Calculate <span class="text-emerald-400">Position Size</span> in Forex
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-sm leading-relaxed">
        Position sizing determines how many lots to trade so that a losing trade costs exactly your planned risk — no more. Every professional trader uses a position size calculator before every entry.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {[
        {
          n: '01',
          title: 'Set Your Account Risk',
          body: 'Decide what percentage of your account you will risk per trade. Professional traders use 0.5%–1%. On a $10,000 account at 1% risk, your maximum loss per trade is $100.',
        },
        {
          n: '02',
          title: 'Measure Your Stop Loss',
          body: 'Place your stop loss at a level that truly invalidates your setup — outside normal market noise. Measure the distance between entry and stop in pips or points.',
        },
        {
          n: '03',
          title: 'Divide by Pip Value',
          body: 'Divide your dollar risk by the stop loss distance multiplied by the pip value for your instrument. The result is your lot size in standard lots.',
        },
      ].map(({ n, title, body }) => (
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
          <div class="text-4xl font-black text-emerald-500/30 mb-4">{n}</div>
          <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-3">{title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{body}</p>
        </div>
      ))}
    </div>

    <!-- Formula -->
    <div class="bg-slate-900 border border-emerald-500/20 rounded-2xl p-6 mb-12">
      <h3 class="text-emerald-400 font-black uppercase text-xs tracking-widest mb-4">
        Position Size Formula
      </h3>
      <div class="font-mono text-sm text-slate-200 space-y-2">
        <p><span class="text-slate-500">Risk Amount ($)  </span> = Account Balance × (Risk % ÷ 100)</p>
        <p><span class="text-slate-500">Pip Distance     </span> = |Entry Price − Stop Loss| ÷ Pip Size</p>
        <p><span class="text-slate-500">Lot Size         </span> = Risk Amount ÷ (Pip Distance × Pip Value per Lot)</p>
      </div>
    </div>

    <!-- Static example trade table — crawlable by Google without JS -->
    <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden mb-12">
      <div class="px-6 py-4 border-b border-slate-800">
        <h3 class="text-white font-black uppercase text-sm tracking-tighter">
          Worked Example — EUR/USD, $10,000 Account
        </h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <tbody>
            {[
              ['Account Balance',     '$10,000'],
              ['Risk Percentage',     '1%'],
              ['Dollar Risk',         '$100'],
              ['Entry Price',         '1.08500'],
              ['Stop Loss Price',     '1.08200'],
              ['Stop Loss Distance',  '30 pips'],
              ['EUR/USD Pip Value',   '$10.00 per standard lot'],
              ['Calculation',         '$100 ÷ (30 pips × $10.00)'],
              ['Lot Size',            '0.33 standard lots'],
            ].map(([label, value], i) => (
              <tr class={i % 2 === 0 ? 'bg-slate-950/30' : ''}>
                <td class="px-6 py-3 text-slate-400 font-medium">{label}</td>
                <td class={`px-6 py-3 font-mono font-bold ${label === 'Lot Size' ? 'text-emerald-400 text-base' : 'text-slate-200'}`}>
                  {value}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Why it matters + pip value reference -->
    <div class="grid md:grid-cols-2 gap-10 items-start">
      <div>
        <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-4 border-l-4 border-emerald-500 pl-4">
          Why Position Sizing Matters
        </h2>
        <div class="space-y-3 text-slate-400 text-sm leading-relaxed">
          <p>
            Most retail traders lose accounts not from bad entries but from incorrect position sizing. One oversized trade can erase weeks of consistent gains in a single session.
          </p>
          <p>
            Professional forex traders — especially those funded through FTMO, MyForexFunds, The5ers, and similar prop firms — treat position sizing as the non-negotiable foundation of every trade. The lot size is what determines your actual dollar risk, regardless of what percentage you intend to risk.
          </p>
          <p>
            For prop firm challenges with 4–5% daily loss limits and 8–10% max drawdown rules, a single over-sized losing trade can end your evaluation on day one. Risk 0.5%–1% per trade and protect the account at all costs.
          </p>
        </div>
      </div>
      <div>
        <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-4">
          Pip Values by Instrument
        </h3>
        <div class="space-y-0 divide-y divide-slate-800/50">
          {[
            { inst: 'EUR/USD, GBP/USD, AUD/USD', pip: '$10.00 / lot / pip' },
            { inst: 'USD/JPY',                    pip: '~$6.70 / lot / pip' },
            { inst: 'USD/CHF',                    pip: '~$10.50 / lot / pip' },
            { inst: 'Gold (XAU/USD)',             pip: '$1.00 / lot / pip' },
            { inst: 'Silver (XAG/USD)',           pip: '$0.50 / lot / pip' },
            { inst: 'NAS100 / US30 / SPX500',    pip: '$1.00 / lot / point' },
            { inst: 'BTC/USD, ETH/USD',           pip: '$1.00 / lot / point' },
          ].map(({ inst, pip }) => (
            <div class="flex justify-between items-center py-3 text-xs">
              <span class="text-slate-300 font-bold">{inst}</span>
              <span class="text-emerald-400 font-mono font-bold">{pip}</span>
            </div>
          ))}
        </div>
        <a href="/calculator/" class="mt-4 inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors">
          Full instrument list →
        </a>
      </div>
    </div>
  </section>

  <!-- ── All Calculators Grid ────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto pb-12 px-6">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white border-l-4 border-emerald-500 pl-4">
        45+ Instrument Calculators
      </h2>
      <a href="/calculator/" class="text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors">
        View All →
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {featuredCalcs.map(({ symbol, name, label }) => (
        <a
          href={`/calculator/${getSlug(symbol)}/`}
          class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-4 transition-all hover:-translate-y-0.5"
        >
          <div class="text-emerald-400 font-black text-sm tracking-tight group-hover:text-emerald-300 mb-1 truncate">{name}</div>
          <div class="text-slate-600 text-[9px] uppercase tracking-widest font-bold">{label}</div>
          <div class="mt-2 text-[9px] text-slate-700 group-hover:text-emerald-500/60 uppercase tracking-widest font-bold transition-colors">
            Calculate →
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Trust bar ───────────────────────────────────────────────── -->
  <section class="border-y border-slate-800/50 bg-slate-950/50">
    <div class="max-w-5xl mx-auto py-12 px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        {[
          { value: '45+',  label: 'Instruments Supported', sub: 'Forex, Gold, Indices, Crypto' },
          { value: '100',  label: 'PageSpeed Score',        sub: 'Fastest calculator available' },
          { value: 'Free', label: 'No Cost, Ever',          sub: 'No account or sign-up needed' },
        ].map(({ value, label, sub }) => (
          <div>
            <div class="text-4xl font-black text-emerald-400 mb-1">{value}</div>
            <div class="text-white font-black uppercase text-xs tracking-widest">{label}</div>
            <div class="text-slate-500 text-[10px] mt-1">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ─────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto py-20 px-6">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-2">
        Position Sizing <span class="text-emerald-400">FAQ</span>
      </h2>
      <p class="text-slate-500 text-xs uppercase tracking-widest font-bold">
        Lot Size, Risk Management & Forex Calculator Questions
      </p>
    </div>

    <div class="space-y-3">
      {[
        {
          q: "What is a forex position size calculator?",
          a: "A forex position size calculator determines how many lots to trade based on your account balance, risk percentage, and stop loss distance. It ensures your worst-case loss equals your planned risk — for example, 1% of a $10,000 account is $100 risk, no matter how far away the stop is.",
        },
        {
          q: "How do I calculate lot size in forex?",
          a: "Lot Size = (Account Balance × Risk%) ÷ (Stop Loss in Pips × Pip Value per Lot). Example: $10,000 × 1% = $100 ÷ (30 pips × $10) = 0.33 lots on EUR/USD. The TRADE90 calculator handles all pip value conversions automatically for all 45+ instruments.",
        },
        {
          q: "What percentage should I risk per forex trade?",
          a: "Professional traders and FTMO-funded accounts use 0.5%–1% per trade. At 1% risk, five consecutive losses reduce the account by only 4.9% — well within most prop firm drawdown limits. Risking more than 2% per trade is considered reckless by institutional standards.",
        },
        {
          q: "What is a standard lot in forex?",
          a: "A standard lot is 100,000 units of the base currency. On EUR/USD, 1 standard lot = €100,000. A mini lot is 0.10 lots and a micro lot is 0.01 lots. Position size calculators output in standard lots — 0.33 lots means 33,000 units of the base currency.",
        },
        {
          q: "How do FTMO and prop firms calculate position size?",
          a: "FTMO challenges use a 4–5% daily loss limit and 8–10% max drawdown. Sizing at 0.5%–1% per trade keeps you inside those limits even through losing streaks. Always use your current account equity (not starting balance) when calculating, since drawdown limits are applied to real-time equity.",
        },
        {
          q: "Does position sizing work differently for gold and indices?",
          a: "Yes. Gold (XAU/USD) uses $1 pip value per standard lot (1 pip = $0.01). A $10 move = 1,000 pips = $1,000 per lot. Indices like NAS100, US30, and SPX500 use points, with values varying by broker contract. The TRADE90 calculator pre-configures the correct pip/point values for all 45+ instruments automatically.",
        },
      ].map(({ q, a }) => (
        <details class="group bg-slate-900/40 border border-slate-800 hover:border-emerald-500/30 rounded-2xl overflow-hidden transition-colors">
          <summary class="flex justify-between items-center p-5 cursor-pointer font-bold text-slate-200 text-sm uppercase tracking-tight hover:text-white list-none">
            {q}
            <span class="text-emerald-500 group-open:rotate-45 transition-transform text-xl leading-none shrink-0 ml-4">+</span>
          </summary>
          <div class="px-5 pb-5 text-slate-400 text-sm leading-relaxed border-t border-slate-800/50 pt-4">
            {a}
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── Latest Analysis ─────────────────────────────────────────── -->
  <section class="max-w-5xl mx-auto pb-20 px-6">
    <div class="flex items-center justify-between mb-10">
      <header>
        <h2 class="text-xl font-black border-l-4 border-emerald-500 pl-4 uppercase tracking-tighter text-slate-200">
          Latest Analysis
        </h2>
        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest pl-5 mt-1">
          Volatility & Risk Framework Reports
        </p>
      </header>
      <a href="/blog/" class="group flex items-center gap-2 text-[10px] font-black text-emerald-500 uppercase tracking-widest hover:text-white transition-all">
        All Reports <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <BlogCard
            title={post.title}
            excerpt={post.excerpt ?? ''}
            image={post.feature_image ?? undefined}
            slug={post.slug}
            date={post.published_at}
            readingTime={post.reading_time ?? undefined}
            tags={post.tags}
            index={i}
          />
        ))}
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { href: '/calculator/xauusd/', title: 'Gold (XAU/USD) Position Size Calculator', desc: 'Exact lot size for gold CFD trades. Uses $1/pip gold pip value formula with automatic conversion.' },
          { href: '/calculator/nas100/', title: 'NAS100 Position Size Calculator', desc: 'Nasdaq 100 index CFD lot size with automatic point value calculation for prop firm traders.' },
          { href: '/calculator/btcusd/', title: 'Bitcoin (BTC/USD) Lot Size Calculator', desc: 'Risk-managed Bitcoin position sizing for crypto CFD traders using institutional risk formulas.' },
        ].map(({ href, title, desc }) => (
          <a href={href} class="group block bg-slate-900/40 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 transition-all">
            <h3 class="text-white font-black uppercase tracking-tighter text-base mb-2 group-hover:text-emerald-400 transition-colors">{title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{desc}</p>
            <span class="mt-4 inline-block text-[10px] font-black uppercase tracking-widest text-emerald-500">Open Calculator →</span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
