---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubArticleList from '../../components/HubArticleList.astro';

const title = "Risk Management for Funded Traders — The Complete Framework";
const description = "Position sizing, daily loss limits, drawdown mechanics, and risk of ruin. The risk management framework that keeps funded accounts alive through losing streaks.";

const site = Astro.site?.toString() || "https://tradeninety.com";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is the best risk percentage for a prop firm challenge?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "0.5% per trade is the recommended maximum for funded account challenges. At 0.5%, you can absorb 20 consecutive losses before reaching a typical 10% maximum drawdown. Risking 1% per trade is the absolute ceiling for a funded account — exceeding it places the challenge at serious risk from any normal losing streak.",
      },
    },
    {
      "@type": "Question",
      name: "What is the 0.5% rule in funded trading?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The 0.5% rule means you risk no more than 0.5% of your current account equity on any single trade. On a $100,000 funded account that equals $500 maximum risk per trade. At 0.5% per trade, you need 8–10 consecutive losses before approaching a typical 4–5% daily loss limit.",
      },
    },
    {
      "@type": "Question",
      name: "What is a daily loss limit on a prop firm challenge?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Most prop firms set a daily loss limit of 4–5% of account balance. A personal daily cap of 1% — well inside the firm's limit — preserves a buffer against intraday volatility and prevents hitting the hard limit from a single bad session.",
      },
    },
    {
      "@type": "Question",
      name: "How many trades per day should a funded trader take?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Two trades per day is the recommended maximum during funded evaluations. At 0.5% risk per trade, two trades equals 1% maximum daily exposure. Two trades forces selectivity and eliminates over-trading from boredom or frustration.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Risk Management", item: `${site}/risk-management/` },
  ],
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />

  <!-- Hero -->
  <section class="py-14 px-4 border-b border-slate-800 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <span class="text-slate-300">Risk Management</span>
      </nav>

      <span class="text-[9px] font-black uppercase tracking-widest text-emerald-400 bg-emerald-500/10 px-3 py-1 rounded-full mb-4 inline-block">Knowledge Hub</span>
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-4 leading-tight">
        Risk <span class="text-emerald-400">Management</span>
      </h1>
      <p class="text-slate-400 text-base leading-relaxed max-w-2xl mb-4">
        The mathematics that decides whether your account survives long enough for your edge to work. Position sizing, daily loss limits, drawdown mechanics, and risk of ruin — explained completely, without hype.
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto py-16 px-6 space-y-16">

    <!-- Why it matters -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
        Why Most Funded Traders Fail
      </h2>
      <div class="space-y-4 text-slate-400 text-sm leading-relaxed">
        <p>
          The most common reason funded account challenges fail is not a bad strategy. It is <strong class="text-slate-200">oversized positions during losing streaks</strong>. A trader with a winning edge can still blow a challenge by risking 2% per trade and hitting five consecutive losses — a statistically normal event that costs nearly 10% of the account.
        </p>
        <p>
          Risk management for funded accounts is not the same as risk management for retail accounts. The consequences of breaching a daily or total drawdown limit are immediate and final: the challenge is failed, the fee is lost, and the process starts again.
        </p>
        <p>
          The framework below is designed around one goal: <strong class="text-slate-200">keeping your account alive long enough for your strategy to work</strong>.
        </p>
      </div>
    </section>

    <!-- The Four Rules -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-2 border-l-4 border-emerald-500 pl-4">
        The Four Rules
      </h2>
      <p class="text-slate-500 text-xs uppercase tracking-widest font-bold pl-5 mb-8">
        Trade90 framework — internal discipline guidelines, not official prop firm rules
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            n: "01",
            title: "0.5% Maximum Risk Per Trade",
            body: "Never risk more than 0.5% of your current account balance on any single trade idea. Use current equity, not starting balance — as drawdown accumulates, the dollar amount per trade shrinks automatically, which is correct behavior.",
            code: [
              "5 losses at 0.5% → −2.5%  (safe)",
              "5 losses at 1.0% → −4.9%  (borderline)",
              "5 losses at 2.0% → −9.6%  (challenge at risk)",
            ],
          },
          {
            n: "02",
            title: "1% Personal Daily Risk Cap",
            body: "Set your personal daily stop at 1% of account equity — well inside the typical prop firm daily limit of 4–5%. When total risk across all trades reaches 1%, stop trading for the day.",
            code: [
              "Trade 1:  0.5% risk  →  half budget used",
              "Trade 2:  0.5% risk  →  budget spent",
              "Result:   stop trading, firm limit intact",
            ],
          },
          {
            n: "03",
            title: "Two Trades Per Day Maximum",
            body: "At 0.5% per trade, two trades equals exactly the 1% daily cap. Two trades forces selectivity: you wait for the clearest setups, not the first opportunity. Over-trading is the second most common cause of funded account failures.",
            code: [
              "2 trades × 0.5% = 1.0% daily exposure",
              "Firm limit:       typically 4–5% daily",
              "Your buffer:      3–4% intact",
            ],
          },
          {
            n: "04",
            title: "Check ADR Before Entry",
            body: "Verify the Average Daily Range before every trade. If the instrument has already consumed most of its ADR before your setup triggers, the remaining range is thin and the trade carries elevated stop-hunt risk.",
            code: [
              "ADR mostly consumed → pass the trade",
              "ADR mostly intact   → full range available",
            ],
          },
        ].map(({ n, title, body, code }) => (
          <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
            <div class="text-4xl font-black text-emerald-500/20 mb-3">{n}</div>
            <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-3">{title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{body}</p>
            <div class="bg-slate-950/60 rounded-xl p-4 font-mono text-xs space-y-1">
              {code.map((line) => (
                <p class="text-slate-500">{line}</p>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Drawdown Survival Table -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-4 border-l-4 border-emerald-500 pl-4">
        Drawdown Survival — $100,000 Account
      </h2>
      <p class="text-slate-400 text-sm leading-relaxed mb-6">
        Account drawdown after consecutive losses at different risk levels, against standard prop firm limits. This is pure compounding math — it applies to every strategy and every firm.
      </p>

      <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden mb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-800">
                <th class="px-5 py-4 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Risk / Trade</th>
                <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">5 Losses</th>
                <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">10 Losses</th>
                <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">15 Losses</th>
                <th class="px-5 py-4 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">Challenge Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/50">
              {[
                { risk: "0.5%", l5: "−2.5%", l10: "−4.9%", l15: "−7.1%", status: "Safe — inside all limits", color: "text-emerald-400" },
                { risk: "1.0%", l5: "−4.9%", l10: "−9.6%", l15: "−14.0%", status: "Borderline — near 10% max DD", color: "text-amber-400" },
                { risk: "1.5%", l5: "−7.1%", l10: "−13.8%", l15: "−20.0%", status: "Dangerous — exceeds max DD", color: "text-orange-400" },
                { risk: "2.0%", l5: "−9.2%", l10: "−17.6%", l15: "−25.3%", status: "Failed at 5 losses (most firms)", color: "text-rose-400" },
              ].map(({ risk, l5, l10, l15, status, color }) => (
                <tr>
                  <td class={`px-5 py-3 font-black font-mono ${color}`}>{risk}</td>
                  <td class="px-5 py-3 text-right text-slate-300 font-mono text-xs">{l5}</td>
                  <td class="px-5 py-3 text-right text-slate-300 font-mono text-xs">{l10}</td>
                  <td class="px-5 py-3 text-right text-slate-300 font-mono text-xs">{l15}</td>
                  <td class={`px-5 py-3 text-right font-black text-xs uppercase ${color}`}>{status}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="text-slate-500 text-xs">Compound drawdown on rolling equity. Most prop firms use a 10% maximum total drawdown and a 4–5% daily loss limit. Model your own numbers with the <a href="/tools/drawdown-calculator/" class="text-emerald-400 hover:text-white transition-colors">drawdown calculator</a>.</p>
    </section>

    <!-- Foundation guide -->
    <section>
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-8 border-l-4 border-emerald-500 pl-4">
        Start Here
      </h2>
      <a
        href="/risk-management/position-sizing/"
        class="group block bg-slate-900/50 border border-emerald-500/25 hover:border-emerald-500/60 rounded-2xl p-6 transition-all"
      >
        <div class="flex items-center justify-between mb-3">
          <span class="text-[9px] font-black uppercase tracking-widest text-emerald-500">Foundation Guide</span>
          <span class="text-[9px] text-slate-600 font-bold uppercase tracking-widest">12 min read</span>
        </div>
        <h3 class="text-white font-black uppercase tracking-tighter text-lg mb-2 group-hover:text-emerald-400 transition-colors">
          Position Sizing: The Complete Guide
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          The formula, pip values across forex, gold, indices and crypto, worked examples, and the five sizing mistakes that blow accounts.
        </p>
        <span class="mt-4 inline-block text-[10px] font-black uppercase tracking-widest text-emerald-500">Read →</span>
      </a>
    </section>

    <!-- Article list -->
    <HubArticleList hub="risk-management" heading="Deep Dives" />

    <!-- Tool CTA -->
    <section class="bg-slate-900/40 border border-emerald-500/20 rounded-2xl p-8 text-center">
      <h2 class="text-xl font-black uppercase tracking-tighter text-white mb-3">
        Apply the Framework
      </h2>
      <p class="text-slate-400 text-sm mb-6 max-w-lg mx-auto">
        The position size calculator enforces these limits in real time — risk state, daily budget remaining, and safe trades left.
      </p>
      <a
        href="/tools/position-size-calculator/"
        class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-sm px-6 py-3 rounded-xl transition-colors"
      >
        Open Position Size Calculator →
      </a>
    </section>

    <!-- Continue -->
    <section class="border-t border-slate-800 pt-12">
      <h2 class="text-lg font-black uppercase tracking-tighter text-white mb-6">Related Hubs</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/psychology/" class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-5 transition-all">
          <p class="text-[9px] font-black uppercase tracking-widest text-sky-400 mb-1">Psychology</p>
          <p class="text-white font-black uppercase tracking-tighter text-sm group-hover:text-emerald-400 transition-colors">Why discipline beats talent →</p>
        </a>
        <a href="/trading-plans/" class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-5 transition-all">
          <p class="text-[9px] font-black uppercase tracking-widest text-amber-400 mb-1">Trading Plans</p>
          <p class="text-white font-black uppercase tracking-tighter text-sm group-hover:text-emerald-400 transition-colors">Turn rules into a written plan →</p>
        </a>
        <a href="/prop-firms/" class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-5 transition-all">
          <p class="text-[9px] font-black uppercase tracking-widest text-purple-400 mb-1">Prop Firms</p>
          <p class="text-white font-black uppercase tracking-tighter text-sm group-hover:text-emerald-400 transition-colors">Evaluations and funded accounts →</p>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
