---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Profit Calculator — Forex, Gold & Index Trade Profit/Loss Estimator";
const description = "Estimate the dollar profit or loss of a trade from your instrument, lot size, and pip movement. Free profit/loss calculator for forex, gold, indices, and crypto.";
const keywords = [
  "profit calculator",
  "forex profit calculator",
  "trade profit loss calculator",
  "pip profit calculator",
  "lot size profit calculator",
];

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

// Value per 1.0 standard lot, per 1 pip/point of movement (USD, approximate)
const instruments = [
  { sym: "EURUSD", label: "EUR/USD",  unit: "pips",   valuePerLot: 10 },
  { sym: "GBPUSD", label: "GBP/USD",  unit: "pips",   valuePerLot: 10 },
  { sym: "USDJPY", label: "USD/JPY",  unit: "pips",   valuePerLot: 6.7 },
  { sym: "AUDUSD", label: "AUD/USD",  unit: "pips",   valuePerLot: 10 },
  { sym: "EURGBP", label: "EUR/GBP",  unit: "pips",   valuePerLot: 12.6 },
  { sym: "XAUUSD", label: "Gold (XAU/USD)", unit: "points", valuePerLot: 100 },
  { sym: "XAGUSD", label: "Silver (XAG/USD)", unit: "points", valuePerLot: 50 },
  { sym: "NAS100", label: "NAS100",   unit: "points", valuePerLot: 10 },
  { sym: "US30",   label: "US30 (Dow)", unit: "points", valuePerLot: 10 },
  { sym: "SPX500", label: "S&P 500",  unit: "points", valuePerLot: 10 },
  { sym: "GER40",  label: "GER40 (DAX)", unit: "points", valuePerLot: 1.2 },
  { sym: "BTCUSD", label: "Bitcoin (BTC/USD)", unit: "points", valuePerLot: 1 },
];

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 Profit Calculator",
  description,
  url: canonicalURL,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  creator: { "@type": "Organization", name: "TRADE90", url: site },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Tools", item: `${site}/tools/` },
    { "@type": "ListItem", position: 3, name: "Profit Calculator", item: canonicalURL },
  ],
};
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />

  <section class="py-12 px-4 border-b border-slate-800 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/12 via-slate-950 to-slate-950">
    <div class="max-w-2xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/tools/" class="hover:text-emerald-400 transition-colors">Tools</a>
        <span aria-hidden="true">/</span>
        <span class="text-slate-300">Profit Calculator</span>
      </nav>

      <h1 class="text-3xl md:text-4xl font-black uppercase tracking-tighter text-white mb-3 text-center">
        Profit <span class="text-emerald-400">Calculator</span>
      </h1>
      <p class="text-slate-400 text-sm leading-relaxed mb-8 max-w-lg mx-auto text-center">
        Estimate the dollar result of a trade from your instrument, lot size, and how far price moves in your favor or against you.
      </p>

      <div class="bg-slate-900/40 rounded-3xl border border-slate-800/60 p-6 md:p-8">
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div class="sm:col-span-2">
            <label for="p-inst" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Instrument</label>
            <select id="p-inst" class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white font-mono text-sm outline-none transition-colors">
              {instruments.map((i) => (
                <option value={i.sym} data-value={i.valuePerLot} data-unit={i.unit}>{i.label}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="p-lots" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Lot Size (standard lots)</label>
            <input id="p-lots" type="number" inputmode="decimal" value="1.00" step="0.01" min="0" class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white font-mono text-sm outline-none transition-colors" />
          </div>
          <div>
            <label for="p-move" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Movement (<span id="p-unit">pips</span>)</label>
            <input id="p-move" type="number" inputmode="decimal" value="25" step="1" class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white font-mono text-sm outline-none transition-colors" />
          </div>
        </div>

        <div class="flex gap-2 mb-6">
          <button id="p-dir-win" type="button" class="flex-1 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border transition-colors">In My Favor</button>
          <button id="p-dir-loss" type="button" class="flex-1 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border transition-colors">Against Me</button>
        </div>

        <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-6 text-center">
          <p class="text-[9px] font-black uppercase tracking-widest text-slate-500 mb-2">Estimated Result</p>
          <p id="p-out" class="text-4xl font-black font-mono">—</p>
          <p id="p-detail" class="text-slate-500 text-xs font-mono mt-2"></p>
        </div>
      </div>

      <p class="text-slate-600 text-[11px] leading-relaxed mt-4 text-center max-w-lg mx-auto">
        Pip/point values are approximate and vary by broker contract. For exact position sizing, use the
        <a href="/tools/position-size-calculator/" class="text-emerald-400 hover:text-white transition-colors">position size calculator</a>.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto py-14 px-6">
    <section class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6">
      <p class="text-[10px] font-black uppercase tracking-widest text-emerald-400 mb-2">Size Before You Profit</p>
      <p class="text-slate-400 text-sm leading-relaxed mb-4">
        Estimating profit is the easy part. Deciding how large to trade — so a loss costs a controlled, known amount — is what actually protects your account. Start with the position sizing guide.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/risk-management/position-sizing/" class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-xs px-4 py-2.5 rounded-xl transition-colors">Position Sizing Guide →</a>
        <a href="/tools/position-size-calculator/" class="inline-flex items-center gap-2 border border-slate-700 hover:border-emerald-500/50 text-slate-300 font-black uppercase tracking-widest text-xs px-4 py-2.5 rounded-xl transition-colors">Position Size Calculator</a>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      const $ = (id) => document.getElementById(id);
      const inst = $("p-inst"), lots = $("p-lots"), move = $("p-move"), unit = $("p-unit");
      const out = $("p-out"), detail = $("p-detail");
      const winBtn = $("p-dir-win"), lossBtn = $("p-dir-loss");
      let favorable = true;
      const usd = (n) => "$" + Math.abs(n).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });

      function setDir(fav) {
        favorable = fav;
        const on = "bg-emerald-500/15 border-emerald-500/50 text-emerald-400";
        const off = "bg-slate-950 border-slate-700 text-slate-500";
        winBtn.className = "flex-1 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border transition-colors " + (fav ? on : off);
        lossBtn.className = "flex-1 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border transition-colors " + (fav ? off : "bg-rose-500/15 border-rose-500/50 text-rose-400");
        compute();
      }

      function compute() {
        const opt = inst.options[inst.selectedIndex];
        const valuePerLot = parseFloat(opt.dataset.value) || 0;
        const u = opt.dataset.unit || "pips";
        unit.textContent = u;
        const l = parseFloat(lots.value) || 0;
        const mv = parseFloat(move.value) || 0;
        const magnitude = l * mv * valuePerLot;
        const result = favorable ? magnitude : -magnitude;
        if (l <= 0 || mv <= 0) {
          out.textContent = "—";
          out.style.color = "#e2e8f0";
          detail.textContent = "";
          return;
        }
        out.textContent = (result >= 0 ? "+" : "−") + usd(result);
        out.style.color = result >= 0 ? "#34d399" : "#fb7185";
        detail.textContent = l.toFixed(2) + " lots × " + mv + " " + u + " × $" + valuePerLot + "/lot";
      }

      [inst, lots, move].forEach((el) => el.addEventListener("input", compute));
      winBtn.addEventListener("click", () => setDir(true));
      lossBtn.addEventListener("click", () => setDir(false));
      setDir(true);
    })();
  </script>
</BaseLayout>
