---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Drawdown Calculator — Losing Streak & Recovery Calculator";
const description = "Calculate account drawdown after a losing streak at any risk level, and the gain required to recover. Free tool for funded traders managing prop firm drawdown limits.";
const keywords = [
  "drawdown calculator",
  "trading drawdown calculator",
  "losing streak calculator",
  "drawdown recovery calculator",
  "prop firm drawdown",
];

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 Drawdown Calculator",
  description,
  url: canonicalURL,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  creator: { "@type": "Organization", name: "TRADE90", url: site },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Tools", item: `${site}/tools/` },
    { "@type": "ListItem", position: 3, name: "Drawdown Calculator", item: canonicalURL },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How is drawdown recovery calculated?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Recovery is asymmetric. To recover from a drawdown of D%, you need a gain of D / (100 − D) × 100 percent. A 10% drawdown needs 11.1% to recover; a 20% drawdown needs 25%; a 50% drawdown needs 100%. This is why controlling drawdown depth matters more than chasing returns.",
      },
    },
    {
      "@type": "Question",
      name: "How many losses can a funded account survive?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "It depends on your risk per trade. At 0.5% per trade, roughly 20 consecutive losses reach a 10% maximum drawdown; at 1% about 10 losses; at 2% about 5 losses. Because losing streaks are statistically normal, lower risk per trade dramatically increases the number of losses your account can absorb.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />

  <section class="py-12 px-4 border-b border-slate-800 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/12 via-slate-950 to-slate-950">
    <div class="max-w-2xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/tools/" class="hover:text-emerald-400 transition-colors">Tools</a>
        <span aria-hidden="true">/</span>
        <span class="text-slate-300">Drawdown Calculator</span>
      </nav>

      <h1 class="text-3xl md:text-4xl font-black uppercase tracking-tighter text-white mb-3 text-center">
        Drawdown <span class="text-emerald-400">Calculator</span>
      </h1>
      <p class="text-slate-400 text-sm leading-relaxed mb-8 max-w-lg mx-auto text-center">
        See how far a losing streak draws down your account — and the gain required to climb back. Recovery is asymmetric, which is exactly why drawdown control matters.
      </p>

      <!-- Calculator -->
      <div class="bg-slate-900/40 rounded-3xl border border-slate-800/60 p-6 md:p-8">
        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div>
            <label for="dd-balance" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Account Balance ($)</label>
            <input id="dd-balance" type="number" inputmode="decimal" value="100000" min="1" class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white font-mono text-sm outline-none transition-colors" />
          </div>
          <div>
            <label for="dd-risk" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Risk Per Trade (%)</label>
            <input id="dd-risk" type="number" inputmode="decimal" value="0.5" step="0.1" min="0.01" class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white font-mono text-sm outline-none transition-colors" />
          </div>
          <div>
            <label for="dd-losses" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Consecutive Losses</label>
            <input id="dd-losses" type="number" inputmode="numeric" value="10" step="1" min="1" max="100" class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 rounded-xl px-4 py-3 text-white font-mono text-sm outline-none transition-colors" />
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-4 text-center">
            <p class="text-[9px] font-black uppercase tracking-widest text-slate-500 mb-1">Drawdown</p>
            <p id="dd-out-pct" class="text-2xl font-black text-rose-400 font-mono">—</p>
          </div>
          <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-4 text-center">
            <p class="text-[9px] font-black uppercase tracking-widest text-slate-500 mb-1">Dollar Loss</p>
            <p id="dd-out-loss" class="text-2xl font-black text-slate-200 font-mono">—</p>
          </div>
          <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-4 text-center">
            <p class="text-[9px] font-black uppercase tracking-widest text-slate-500 mb-1">Remaining</p>
            <p id="dd-out-bal" class="text-2xl font-black text-slate-200 font-mono">—</p>
          </div>
          <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-4 text-center">
            <p class="text-[9px] font-black uppercase tracking-widest text-slate-500 mb-1">Gain to Recover</p>
            <p id="dd-out-recover" class="text-2xl font-black text-emerald-400 font-mono">—</p>
          </div>
        </div>

        <p id="dd-verdict" class="text-center text-xs font-bold mt-5"></p>
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto py-14 px-6 space-y-12">
    <!-- Reference table -->
    <section>
      <h2 class="text-xl font-black uppercase tracking-tighter text-white mb-4 border-l-4 border-emerald-500 pl-4">
        The Recovery Asymmetry
      </h2>
      <p class="text-slate-400 text-sm leading-relaxed mb-6">
        The deeper the hole, the disproportionately larger the climb out. This is pure arithmetic — and the single strongest argument for keeping risk per trade small.
      </p>
      <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-800">
                <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-slate-500">Drawdown</th>
                <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">Gain Required to Recover</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800/50">
              {[
                ["5%", "5.3%"],
                ["10%", "11.1%"],
                ["20%", "25.0%"],
                ["30%", "42.9%"],
                ["50%", "100.0%"],
                ["75%", "300.0%"],
              ].map(([dd, rec], i) => (
                <tr class={i >= 3 ? "bg-rose-500/5" : ""}>
                  <td class="px-5 py-3 text-slate-200 font-mono font-bold">{dd}</td>
                  <td class="px-5 py-3 text-right text-emerald-400 font-mono font-bold">{rec}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6">
      <p class="text-[10px] font-black uppercase tracking-widest text-emerald-400 mb-2">Go Deeper</p>
      <p class="text-slate-400 text-sm leading-relaxed mb-4">
        Drawdown is the constraint that ends most funded challenges. Understand exactly how the different drawdown types are calculated — including trailing/high-water-mark models — and how to manage them proactively.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/risk-management/drawdown-explained/" class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-xs px-4 py-2.5 rounded-xl transition-colors">Drawdown Explained →</a>
        <a href="/risk-management/" class="inline-flex items-center gap-2 border border-slate-700 hover:border-emerald-500/50 text-slate-300 font-black uppercase tracking-widest text-xs px-4 py-2.5 rounded-xl transition-colors">Risk Management Hub</a>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      const $ = (id) => document.getElementById(id);
      const balance = $("dd-balance"), risk = $("dd-risk"), losses = $("dd-losses");
      const outPct = $("dd-out-pct"), outLoss = $("dd-out-loss"), outBal = $("dd-out-bal"), outRecover = $("dd-out-recover"), verdict = $("dd-verdict");
      const usd = (n) => "$" + Math.round(n).toLocaleString("en-US");

      function compute() {
        const b = parseFloat(balance.value) || 0;
        const r = (parseFloat(risk.value) || 0) / 100;
        const n = Math.max(0, Math.min(100, parseInt(losses.value) || 0));
        if (b <= 0 || r <= 0 || n <= 0) {
          outPct.textContent = outLoss.textContent = outBal.textContent = outRecover.textContent = "—";
          verdict.textContent = "";
          return;
        }
        // Compound drawdown: each loss reduces current equity by r
        const remaining = b * Math.pow(1 - r, n);
        const ddFrac = 1 - Math.pow(1 - r, n);
        const ddPct = ddFrac * 100;
        const loss = b - remaining;
        const recoverPct = ddFrac < 1 ? (ddFrac / (1 - ddFrac)) * 100 : Infinity;

        outPct.textContent = "−" + ddPct.toFixed(1) + "%";
        outLoss.textContent = "−" + usd(loss);
        outBal.textContent = usd(remaining);
        outRecover.textContent = isFinite(recoverPct) ? "+" + recoverPct.toFixed(1) + "%" : "∞";

        let msg, color;
        if (ddPct <= 5) { msg = "Comfortable — well inside typical prop firm limits."; color = "#34d399"; }
        else if (ddPct <= 10) { msg = "Borderline — near a typical 10% maximum drawdown limit."; color = "#fbbf24"; }
        else { msg = "Beyond a typical 10% max drawdown — this streak would end most challenges."; color = "#fb7185"; }
        verdict.textContent = msg;
        verdict.style.color = color;
      }

      [balance, risk, losses].forEach((el) => el.addEventListener("input", compute));
      compute();
    })();
  </script>
</BaseLayout>
