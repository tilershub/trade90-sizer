---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Free Trading Tools — Position Size, Risk, Drawdown & Profit Calculators";
const description = "Free professional calculators for funded traders: position sizing, risk/reward, drawdown, pip value, profit/loss, and compounding. Each tool links to the guide behind it.";

const site = Astro.site?.toString() || "https://tradeninety.com";

const tools = [
  {
    href: "/tools/fx-research-terminal/",
    name: "FX, Gold & Bitcoin Terminal",
    desc: "Scan seven major FX pairs, XAU/USD and BTC/USD with instrument-specific macro drivers, calibrated scenarios, freshness controls and transparent validation.",
    tag: "Market Research",
    learn: { href: "/risk-management/", label: "Risk Management Hub" },
  },
  {
    href: "/tools/position-size-calculator/",
    name: "Position Size Calculator",
    desc: "Find the exact lot size for any trade across 45+ instruments, with funded-account risk limits enforced in real time.",
    tag: "Most Used",
    learn: { href: "/risk-management/position-sizing/", label: "Position Sizing Guide" },
  },
  {
    href: "/tools/trading-plan-builder/",
    name: "Trading Plan Builder",
    desc: "Write the six sections of a complete trading plan — auto-saved in your browser, exported to Markdown or print.",
    tag: "Prepare",
    learn: { href: "/trading-plans/how-to-build-a-trading-plan/", label: "Trading Plan Guide" },
  },
  {
    href: "/journal/",
    name: "Trading Journal",
    desc: "Log trades in R-multiples, grade plan adherence, and track win rate, expectancy, and profit factor live.",
    tag: "Review",
    learn: { href: "/performance/trading-journal-guide/", label: "Journal Guide" },
  },
  {
    href: "/risk-reward-calculator/",
    name: "Risk / Reward Calculator",
    desc: "Calculate your R:R ratio, break-even win rate, and expected value before you take the trade.",
    tag: "Planning",
    learn: { href: "/performance/win-rate-and-profit-factor/", label: "Win Rate & Profit Factor" },
  },
  {
    href: "/tools/drawdown-calculator/",
    name: "Drawdown Calculator",
    desc: "See account drawdown after a losing streak at any risk level — and the gain required to recover.",
    tag: "Risk",
    learn: { href: "/risk-management/drawdown-explained/", label: "Drawdown Explained" },
  },
  {
    href: "/pip-value-calculator/",
    name: "Pip Value Calculator",
    desc: "Look up the pip or point value for forex, gold, indices, and crypto at any lot size.",
    tag: "Reference",
    learn: { href: "/risk-management/position-sizing/", label: "Position Sizing Guide" },
  },
  {
    href: "/tools/profit-calculator/",
    name: "Profit / Loss Calculator",
    desc: "Estimate the dollar result of a trade from your instrument, lot size, and pip movement.",
    tag: "Reference",
    learn: { href: "/risk-management/position-sizing/", label: "Position Sizing Guide" },
  },
  {
    href: "/tools/compounding-calculator/",
    name: "Compounding Calculator",
    desc: "Project how an account grows over time at a steady monthly return — with realistic expectations.",
    tag: "Planning",
    learn: { href: "/performance/expectancy-explained/", label: "Expectancy Explained" },
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Tools", item: `${site}/tools/` },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "TRADE90 Free Trading Tools",
  itemListElement: tools.map((t, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: t.name,
    url: new URL(t.href, site).toString(),
  })),
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head-extra" />

  <section class="py-14 px-4 border-b border-slate-800 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <span class="text-slate-300">Tools</span>
      </nav>
      <span class="text-[9px] font-black uppercase tracking-widest text-emerald-400 bg-emerald-500/10 px-3 py-1 rounded-full mb-4 inline-block">Free Tools</span>
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-4 leading-tight">
        Trading <span class="text-emerald-400">Tools</span>
      </h1>
      <p class="text-slate-400 text-base leading-relaxed max-w-2xl">
        Free, no login required. Each calculator is a supporting tool — paired with the guide that explains the concept behind it, so you understand the number, not just read it.
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto py-16 px-6">
    <div class="grid md:grid-cols-2 gap-5">
      {tools.map((t) => (
        <div class="bg-slate-900/40 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 transition-all flex flex-col">
          <div class="flex items-center justify-between mb-3">
            <span class="text-[9px] font-black uppercase tracking-widest text-emerald-500">{t.tag}</span>
          </div>
          <a href={t.href} class="group">
            <h2 class="text-white font-black uppercase tracking-tighter text-lg mb-2 group-hover:text-emerald-400 transition-colors">{t.name}</h2>
          </a>
          <p class="text-slate-400 text-sm leading-relaxed mb-5 flex-grow">{t.desc}</p>
          <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-slate-800/60">
            <a href={t.href} class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-black uppercase tracking-widest text-xs px-4 py-2 rounded-lg transition-colors">
              Open Tool →
            </a>
            <a href={t.learn.href} class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-emerald-400 transition-colors">
              {t.learn.label} →
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-slate-500 text-sm mt-10">
      Looking for a specific instrument? Browse all
      <a href="/calculator/" class="text-emerald-400 hover:text-white transition-colors">45+ dedicated calculators →</a>
    </p>
  </div>
</BaseLayout>
