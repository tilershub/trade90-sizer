---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "USD/JPY Research Lab — Macro, Trend & Risk Analysis";
const description = "Research USD/JPY with an explainable TRADE90 model combining price trend, momentum, US–Japan yield differentials, volatility, and central-bank policy context.";
const appUrl = "https://usdjpy-research-lab-f8nkfpp3xx4tgonywqxappk.streamlit.app/?embedded=true";

const site = Astro.site?.toString() || "https://tradeninety.com";
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 USD/JPY Research Lab",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  url: new URL("/tools/usdjpy-research/", site).toString(),
  description,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbName="USD/JPY Research Lab"
  breadcrumbParentName="Tools"
  breadcrumbParentPath="/tools/"
  keywords={["USD JPY analysis", "USDJPY research", "yen analysis", "funded trader research tool", "US Japan yield differential"]}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} slot="head-extra" />

  <section class="relative py-14 px-4 border-b border-slate-800 overflow-hidden bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/15 via-slate-950 to-slate-950">
    <div class="max-w-6xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/tools/" class="hover:text-emerald-400 transition-colors">Tools</a>
        <span aria-hidden="true">/</span>
        <span class="text-slate-300">USD/JPY Research</span>
      </nav>

      <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-end">
        <div>
          <span class="text-[9px] font-black uppercase tracking-[0.3em] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-full mb-5 inline-block">TRADE90 Market Research</span>
          <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-5 leading-[0.95]">
            USD/JPY <span class="text-emerald-400">Research Lab</span>
          </h1>
          <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-3xl">
            An explainable swing-research workspace for funded traders. Study price structure, momentum, the US–Japan yield differential, volatility, and policy context before forming your own market view.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3 text-center">
          <div class="bg-slate-900/70 border border-slate-800 rounded-xl px-5 py-4">
            <strong class="block text-emerald-400 text-lg">7</strong>
            <span class="text-[9px] font-black uppercase tracking-widest text-slate-400">Inputs</span>
          </div>
          <div class="bg-slate-900/70 border border-slate-800 rounded-xl px-5 py-4">
            <strong class="block text-emerald-400 text-lg">3</strong>
            <span class="text-[9px] font-black uppercase tracking-widest text-slate-400">Scenarios</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-10 px-4 md:px-6">
    <div class="grid md:grid-cols-3 gap-4 mb-8">
      {[
        ["Macro context", "Track the US–Japan 10-year government-yield differential and its recent impulse."],
        ["Technical structure", "Compare trend, momentum, RSI, and volatility without hiding the inputs."],
        ["Historical simulation", "Stress-test the research rule with lagged positions and configurable costs."],
      ].map(([name, copy]) => (
        <div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-5">
          <h2 class="text-white font-black uppercase tracking-tighter text-sm mb-2">{name}</h2>
          <p class="text-slate-400 text-sm leading-relaxed">{copy}</p>
        </div>
      ))}
    </div>

    <div class="rounded-2xl overflow-hidden border border-slate-700 bg-slate-950 shadow-2xl shadow-emerald-950/10">
      <div class="flex flex-wrap items-center justify-between gap-3 px-5 py-3 border-b border-slate-800 bg-slate-900/80">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-300">Live Research Workspace</span>
        </div>
        <a href={appUrl.replace("/?embedded=true", "")} target="_blank" rel="noopener noreferrer" class="text-[10px] font-black uppercase tracking-widest text-emerald-400 hover:text-white transition-colors">
          Open Full Screen ↗
        </a>
      </div>
      <iframe
        src={appUrl}
        title="TRADE90 USD/JPY Research Lab"
        loading="lazy"
        class="w-full h-[1150px] md:h-[1250px] bg-slate-900"
        allow="clipboard-write"
      ></iframe>
    </div>

    <div class="mt-8 bg-amber-500/5 border border-amber-500/20 rounded-2xl p-5">
      <h2 class="text-amber-300 font-black uppercase tracking-widest text-xs mb-2">Research, not a trade signal</h2>
      <p class="text-slate-400 text-sm leading-relaxed">
        TRADE90 provides education and mathematical research tools. Scenario percentages are interpretations of model evidence, not calibrated forecasts, individualized financial advice, or instructions to buy or sell. Validate the source data and protect your funded-account risk limits before every decision.
      </p>
    </div>
  </section>
</BaseLayout>
