---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "USD/JPY Research Lab — Macro, Trend & Risk Analysis";
const description = "Research USD/JPY with an explainable TRADE90 model combining price trend, momentum, US–Japan yield differentials, volatility, and central-bank policy context.";
const appUrl = "https://usdjpy-research-lab-f8nkfpp3xx4tgonywqxappk.streamlit.app/?embedded=true";

const site = Astro.site?.toString() || "https://tradeninety.com";
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TRADE90 USD/JPY Research Lab",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  url: new URL("/tools/usdjpy-research/", site).toString(),
  description,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbName="USD/JPY Research Lab"
  breadcrumbParentName="Tools"
  breadcrumbParentPath="/tools/"
  keywords={["USD JPY analysis", "USDJPY research", "yen analysis", "funded trader research tool", "US Japan yield differential"]}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} slot="head-extra" />

  <div class="bg-white text-slate-900">
    <section class="relative py-14 px-4 border-b border-slate-200 overflow-hidden bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-100 via-white to-white">
      <div class="max-w-6xl mx-auto">
        <nav aria-label="Breadcrumb" class="mb-8 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
          <a href="/" class="hover:text-emerald-700 transition-colors">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/tools/" class="hover:text-emerald-700 transition-colors">Tools</a>
          <span aria-hidden="true">/</span>
          <span class="text-slate-800">USD/JPY Research</span>
        </nav>

        <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-end">
          <div>
            <span class="text-[9px] font-black uppercase tracking-[0.3em] text-emerald-800 bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full mb-5 inline-block">TRADE90 Market Research</span>
            <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-slate-950 mb-5 leading-[0.95]">
              USD/JPY <span class="text-emerald-700">Research Lab</span>
            </h1>
            <p class="text-slate-600 text-base md:text-lg leading-relaxed max-w-3xl">
              An explainable swing-research workspace for funded traders. Study price structure, momentum, the US–Japan yield differential, volatility, and policy context before forming your own market view.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-3 text-center">
            <div class="bg-white border border-slate-200 shadow-sm rounded-xl px-5 py-4">
              <strong class="block text-emerald-700 text-lg">7</strong>
              <span class="text-[9px] font-black uppercase tracking-widest text-slate-600">Inputs</span>
            </div>
            <div class="bg-white border border-slate-200 shadow-sm rounded-xl px-5 py-4">
              <strong class="block text-emerald-700 text-lg">3</strong>
              <span class="text-[9px] font-black uppercase tracking-widest text-slate-600">Scenarios</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto py-10 px-4 md:px-6">
      <div class="grid md:grid-cols-3 gap-4 mb-8">
        {[
          ["Macro context", "Track the US–Japan 10-year government-yield differential and its recent impulse."],
          ["Technical structure", "Compare trend, momentum, RSI, and volatility without hiding the inputs."],
          ["Historical simulation", "Stress-test the research rule with lagged positions and configurable costs."],
        ].map(([name, copy]) => (
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-5">
            <h2 class="text-slate-950 font-black uppercase tracking-tighter text-sm mb-2">{name}</h2>
            <p class="text-slate-600 text-sm leading-relaxed">{copy}</p>
          </div>
        ))}
      </div>

      <div class="rounded-2xl overflow-hidden border border-slate-300 bg-white shadow-xl shadow-slate-200/70">
        <div class="flex flex-wrap items-center justify-between gap-3 px-5 py-3 border-b border-slate-200 bg-slate-50">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-600"></span>
            <span class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-700">Live Research Workspace</span>
          </div>
          <a href={appUrl.replace("/?embedded=true", "")} target="_blank" rel="noopener noreferrer" class="text-[10px] font-black uppercase tracking-widest text-emerald-700 hover:text-slate-950 transition-colors">
            Open Full Screen ↗
          </a>
        </div>
        <iframe
          src={appUrl}
          title="TRADE90 USD/JPY Research Lab"
          loading="lazy"
          class="block w-full h-[780px] md:h-[900px] bg-white"
          allow="clipboard-write"
        ></iframe>
      </div>

      <p class="mt-3 text-center text-xs text-slate-500">
        Scroll inside the research workspace to view signals, charts, audit details, and the backtest.
      </p>

      <div class="mt-8 bg-amber-50 border border-amber-200 rounded-2xl p-5">
        <h2 class="text-amber-900 font-black uppercase tracking-widest text-xs mb-2">Research, not a trade signal</h2>
        <p class="text-slate-700 text-sm leading-relaxed">
          TRADE90 provides education and mathematical research tools. Scenario percentages are interpretations of model evidence, not calibrated forecasts, individualized financial advice, or instructions to buy or sell. Validate the source data and protect your funded-account risk limits before every decision.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
