---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { INSTRUMENTS, getSlug, CATEGORY_LABELS, type InstrumentConfig } from '../../lib/instruments';

const categories: InstrumentConfig['cat'][] = [
  'Forex Majors',
  'Forex Crosses',
  'Metals',
  'Commodities',
  'Indices',
  'Crypto',
];

const byCategory = Object.fromEntries(
  categories.map(cat => [cat, Object.values(INSTRUMENTS).filter(i => i.cat === cat)])
);

const title = "Position Size Calculators — All Instruments";
const description = "Free position size calculators for 45+ trading instruments. Forex majors, gold, silver, oil, indices, and crypto — each with dedicated pip value formulas and risk management tools.";
const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Calculators", item: canonicalURL },
  ],
};

const allInstruments = Object.values(INSTRUMENTS);
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Position Size Calculators — All Instruments",
  description: description,
  url: canonicalURL,
  numberOfItems: allInstruments.length,
  itemListElement: allInstruments.map((inst, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: `${inst.name} Position Size Calculator`,
    url: new URL(`/calculator/${getSlug(inst.symbol)}/`, site).toString(),
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={["position size calculator", "lot size calculator", "forex calculator", "gold position calculator", "crypto lot size", "risk calculator trading", "ftmo position sizer"]}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head-extra" />

  <!-- Hero -->
  <section class="py-16 px-4 border-b border-slate-800/50 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-5xl mx-auto text-center">
      <nav aria-label="Breadcrumb" class="mb-6 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center justify-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-300">Calculators</span>
      </nav>
      <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-4">
        Position Size <span class="text-emerald-400">Calculators</span>
      </h1>
      <p class="text-slate-400 max-w-2xl mx-auto text-sm leading-relaxed">
        Dedicated calculators for 45+ instruments — each pre-configured with the correct pip value, volatility context, and trading tips. Pick your market below.
      </p>
    </div>
  </section>

  <!-- Instrument Grid by Category -->
  <section class="max-w-5xl mx-auto py-16 px-6 space-y-16">
    {categories.map(cat => (
      <div>
        <h2 class="text-lg font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
          {CATEGORY_LABELS[cat]}
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {byCategory[cat].map(inst => (
            <a
              href={`/calculator/${getSlug(inst.symbol)}/`}
              class="group block bg-slate-900/50 border border-slate-800 hover:border-emerald-500/50 rounded-2xl p-5 transition-all hover:-translate-y-0.5"
            >
              <div class="text-emerald-400 font-black text-base tracking-tight group-hover:text-emerald-300 mb-1">{inst.name}</div>
              <div class="text-slate-500 text-[10px] uppercase tracking-widest font-bold">{inst.fullName}</div>
              <div class="mt-3 text-[10px] text-slate-600 group-hover:text-slate-400 transition-colors uppercase tracking-widest font-bold">
                Calculate →
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- SEO content section -->
  <section class="max-w-5xl mx-auto pb-20 px-6">
    <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-8 md:p-12">
      <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6">How Position Size Calculators Work</h2>
      <div class="prose-custom space-y-4 text-slate-400 text-sm leading-relaxed">
        <p>
          A position size calculator determines the number of lots (or units) to trade based on three inputs: your <strong class="text-slate-200">account balance</strong>, your <strong class="text-slate-200">risk percentage</strong>, and your <strong class="text-slate-200">stop loss distance</strong>. The formula is:
        </p>
        <div class="bg-slate-950 border border-slate-800 rounded-xl p-4 font-mono text-slate-300 text-sm">
          Lot Size = (Account Balance × Risk%) ÷ (SL Pips × Pip Value per Lot)
        </div>
        <p>
          Each instrument has a different pip value. EUR/USD has a pip value of $10 per standard lot per pip. USD/JPY pip values vary with the exchange rate. Gold (XAU/USD) is $10 per pip but each pip is $0.10 — so a $1 move equals $100 per lot. Our calculators handle all of this automatically.
        </p>
        <p>
          Professional traders and FTMO-funded accounts typically risk <strong class="text-slate-200">0.5%–1% per trade</strong>. This allows recovery from losing streaks while keeping position sizes large enough to generate meaningful returns.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
