---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getAllSlugs, getPost, getPostEntry, getRelatedPosts, calcReadingTime } from "../../lib/blog";

export async function getStaticPaths() {
  const slugs = await getAllSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await getPost(slug);
const entry = await getPostEntry(slug);

if (!post || !entry) return Astro.redirect("/blog/", 307);

const { Content } = await render(entry);

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(`/blog/${post.slug}/`, site).toString();

const readingTime = post.reading_time ?? (post.content ? calcReadingTime(post.content) : 1);

// Dates
const publishedISO = post.published_at ? new Date(post.published_at).toISOString() : undefined;
const modifiedISO = post.updated_at ? new Date(post.updated_at).toISOString() : publishedISO;
const formattedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

// SEO
const seoTitle = post.meta_title || post.title;
const seoDescription =
  post.meta_description ||
  post.excerpt ||
  `${post.title} — Market analysis and risk framework intelligence from TRADE90.`;
const ogImage = post.feature_image || "/og-image.jpg";
const keywords = post.tags.slice(0, 10);

// Related posts
const relatedPosts = post.primary_tag
  ? await getRelatedPosts(post.primary_tag, post.id)
  : [];

// JSON-LD schemas
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${site}/blog/` },
    { "@type": "ListItem", position: 3, name: post.title, item: canonicalURL },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
  headline: seoTitle,
  description: seoDescription,
  image: ogImage.startsWith("http") ? ogImage : new URL(ogImage, site).toString(),
  datePublished: publishedISO,
  dateModified: modifiedISO,
  inLanguage: "en",
  timeRequired: `PT${readingTime}M`,
  isAccessibleForFree: true,
  author: {
    "@type": "Organization",
    name: "TRADE90",
    url: site,
  },
  publisher: {
    "@type": "Organization",
    name: "TRADE90",
    url: site,
    logo: { "@type": "ImageObject", url: `${site}favicon.svg` },
  },
  ...(keywords.length ? { keywords: keywords.join(", ") } : {}),
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  ogImage={ogImage}
  articlePublishedTime={publishedISO}
  articleModifiedTime={modifiedISO}
  keywords={keywords}
  breadcrumbName={post.title}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head-extra" />

  <article class="max-w-3xl mx-auto py-16 px-6" itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="datePublished" content={publishedISO} />
    <meta itemprop="dateModified" content={modifiedISO} />

    <header class="mb-16">
      <!-- Breadcrumb nav for UX -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-600">
          <li><a href="/" class="hover:text-emerald-500 transition-colors">Home</a></li>
          <li class="text-slate-800">/</li>
          <li><a href="/blog/" class="hover:text-emerald-500 transition-colors">Blog</a></li>
          <li class="text-slate-800">/</li>
          <li class="text-slate-500 truncate max-w-[200px]" aria-current="page">{post.title}</li>
        </ol>
      </nav>

      <!-- Tags -->
      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {post.tags.slice(0, 4).map((tag) => (
            <a
              href={`/category/${tag.toLowerCase().replace(/\s+/g, '-')}/`}
              class="text-[9px] font-black uppercase tracking-[0.3em] text-emerald-500 border border-emerald-500/30 px-2.5 py-1 rounded-full hover:border-emerald-500 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <time
        class="text-[10px] text-slate-500 font-black uppercase tracking-[0.4em] mb-4 block"
        datetime={publishedISO}
      >
        {formattedDate} &nbsp;·&nbsp; {readingTime} min read
      </time>

      <h1
        class="text-4xl md:text-6xl font-black mt-2 mb-10 tracking-tighter uppercase text-white leading-[0.9] lg:text-7xl"
        itemprop="headline"
      >
        {post.title}
      </h1>

      {post.excerpt && (
        <p class="text-slate-300 text-xl leading-relaxed font-medium border-l-4 border-emerald-500/50 pl-8 py-2 italic">
          {post.excerpt}
        </p>
      )}
    </header>

    <!-- Social Share -->
    <div class="flex items-center gap-3 mb-12 flex-wrap">
      <span class="text-[9px] font-black uppercase tracking-widest text-slate-600 mr-1">Share</span>
      <a
        href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalURL)}&text=${encodeURIComponent(post.title)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 border border-slate-800 hover:border-slate-600 text-slate-400 hover:text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg transition-colors"
        aria-label="Share on X (Twitter)"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X / Twitter
      </a>
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 border border-slate-800 hover:border-slate-600 text-slate-400 hover:text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg transition-colors"
        aria-label="Share on LinkedIn"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a
        href={`https://www.reddit.com/submit?url=${encodeURIComponent(canonicalURL)}&title=${encodeURIComponent(post.title)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 border border-slate-800 hover:border-slate-600 text-slate-400 hover:text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg transition-colors"
        aria-label="Share on Reddit"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
        Reddit
      </a>
    </div>

    {post.feature_image && (
      <figure class="mb-16">
        <img
          src={post.feature_image}
          alt={post.title}
          class="rounded-3xl border border-slate-800 w-full shadow-2xl shadow-emerald-900/10"
          loading="eager"
          decoding="sync"
          fetchpriority="high"
          itemprop="image"
        />
      </figure>
    )}

    <div
      class="prose-blog selection:bg-emerald-500/30"
      itemprop="articleBody"
    >
      <Content />
    </div>

    <!-- Author Bio -->
    <aside class="mt-16 border-t border-slate-900/50 pt-10">
      <div class="flex items-start gap-5">
        <div class="w-14 h-14 rounded-full bg-emerald-900/40 border-2 border-emerald-500/40 flex items-center justify-center shrink-0 text-emerald-400 font-black text-lg select-none">
          T90
        </div>
        <div>
          <p class="text-white font-black text-sm uppercase tracking-wide mb-0.5">TRADE90</p>
          <p class="text-[10px] font-black uppercase tracking-widest text-emerald-500 mb-2">FTMO Funded · 10-Year US Military Veteran</p>
          <p class="text-slate-400 text-sm leading-relaxed">
            Veteran-built institutional risk tools for US-based funded traders. Passed the FTMO evaluation at 0.5% risk per trade.
            Every calculator, guide, and analysis on this site comes from live trading experience — not theory.
            <a href="/about/" class="text-emerald-400 hover:text-white transition-colors ml-1">Learn more →</a>
          </p>
        </div>
      </div>
    </aside>

    <!-- Share after author bio -->
    <div class="mt-8 flex items-center gap-3 flex-wrap">
      <span class="text-[9px] font-black uppercase tracking-widest text-slate-600 mr-1">Found this useful?</span>
      <a
        href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalURL)}&text=${encodeURIComponent(post.title)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 bg-slate-900 border border-slate-800 hover:border-emerald-500/40 hover:text-emerald-400 text-slate-400 text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg transition-colors"
      >Share on X</a>
      <a
        href={`https://www.reddit.com/submit?url=${encodeURIComponent(canonicalURL)}&title=${encodeURIComponent(post.title)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 bg-slate-900 border border-slate-800 hover:border-emerald-500/40 hover:text-emerald-400 text-slate-400 text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg transition-colors"
      >Share on Reddit</a>
    </div>

    <!-- Calculator CTA -->
    <aside class="mt-10 bg-slate-900/70 border border-emerald-500/20 rounded-2xl p-6">
      <p class="text-[10px] font-black uppercase tracking-widest text-emerald-400 mb-2">Free Tool</p>
      <h2 class="text-xl font-black uppercase tracking-tighter text-white mb-2">
        Calculate Your Position Size
      </h2>
      <p class="text-slate-400 text-sm mb-5 leading-relaxed">
        Use the TRADE90 Position Size Calculator to find the exact lot size for any trade — Forex, Gold, Indices, or Crypto — based on your account balance and stop loss. Used by funded traders across the US and Europe.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-black uppercase tracking-widest px-4 py-2.5 rounded-xl transition-colors"
        >
          Open Calculator →
        </a>
        <a
          href="/calculator/"
          class="inline-flex items-center gap-2 border border-slate-700 hover:border-emerald-500/50 text-slate-300 text-xs font-black uppercase tracking-widest px-4 py-2.5 rounded-xl transition-colors"
        >
          All 45+ Instruments
        </a>
      </div>
    </aside>

    {relatedPosts.length > 0 && (
      <section class="mt-12 border-t border-slate-900/50 pt-12">
        <header class="mb-8">
          <p class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-2">
            Continue Analysis
          </p>
          <h2 class="text-2xl font-black text-white uppercase tracking-tighter">
            Related Intelligence
          </h2>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((p) => (
            <BlogCard
              title={p.title}
              excerpt={p.excerpt ?? ''}
              image={p.feature_image ?? undefined}
              slug={p.slug}
              date={p.published_at}
              readingTime={p.reading_time ?? undefined}
              tags={p.tags}
            />
          ))}
        </div>
      </section>
    )}

    <div class="mt-12 pt-12 border-t border-slate-900/50">
      <FAQ showSchema={true} />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Blog post body styles */
  .prose-blog {
    color: #cbd5e1; /* slate-300 */
    font-size: 1rem;
    line-height: 1.8;
  }
  .prose-blog h2 {
    font-size: 1.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    border-left: 4px solid #10b981;
  }
  .prose-blog h3 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #f1f5f9;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .prose-blog h4 {
    font-size: 1rem;
    font-weight: 700;
    color: #10b981;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-blog p {
    margin-bottom: 1.25rem;
  }
  .prose-blog strong, .prose-blog b {
    color: #f1f5f9;
    font-weight: 700;
  }
  .prose-blog em {
    color: #94a3b8;
    font-style: italic;
  }
  .prose-blog a {
    color: #10b981;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(16, 185, 129, 0.4);
    transition: color 0.2s;
  }
  .prose-blog a:hover {
    color: #ffffff;
    text-decoration-color: rgba(255,255,255,0.4);
  }
  .prose-blog ul {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0;
  }
  .prose-blog ul li {
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .prose-blog ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
  }
  .prose-blog ol {
    counter-reset: list;
    padding: 0;
    margin: 1.25rem 0;
  }
  .prose-blog ol li {
    counter-increment: list;
    padding-left: 2rem;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .prose-blog ol li::before {
    content: counter(list) '.';
    position: absolute;
    left: 0;
    color: #10b981;
    font-weight: 800;
    font-size: 0.85em;
  }
  .prose-blog blockquote {
    border-left: 4px solid rgba(16, 185, 129, 0.5);
    padding: 0.75rem 1.5rem;
    margin: 2rem 0;
    color: #94a3b8;
    font-style: italic;
    background: rgba(15, 23, 42, 0.4);
    border-radius: 0 1rem 1rem 0;
  }
  .prose-blog hr {
    border: none;
    border-top: 1px solid rgba(30, 41, 59, 0.8);
    margin: 2.5rem 0;
  }
  .prose-blog table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  .prose-blog th {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.75rem 1rem;
    text-align: left;
    border: 1px solid rgba(30, 41, 59, 0.8);
  }
  .prose-blog td {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(30, 41, 59, 0.8);
    color: #cbd5e1;
  }
  .prose-blog tr:nth-child(even) td {
    background: rgba(15, 23, 42, 0.3);
  }
  .prose-blog code {
    background: rgba(15, 23, 42, 0.8);
    color: #10b981;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: monospace;
  }
  .prose-blog pre {
    background: rgba(15, 23, 42, 0.9);
    border: 1px solid rgba(30, 41, 59, 0.8);
    border-radius: 1rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-blog pre code {
    background: none;
    padding: 0;
  }
  .prose-blog img {
    border-radius: 1rem;
    border: 1px solid rgba(30, 41, 59, 0.6);
    max-width: 100%;
    height: auto;
    margin: 1.5rem auto;
  }
  /* Markdown checkbox items (task lists) */
  .prose-blog input[type="checkbox"] {
    accent-color: #10b981;
    margin-right: 0.5rem;
  }
</style>
