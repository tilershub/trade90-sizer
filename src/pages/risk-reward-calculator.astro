---
import BaseLayout from '../layouts/BaseLayout.astro';

const seoTitle = "Risk Reward Ratio Calculator — R:R Ratio for Forex Trading";
const seoDescription = "Free risk reward ratio calculator for forex and prop firm trading. Calculate R:R ratio, required win rate, and expected value for any trade setup. Includes FTMO strategy guide.";
const keywords = [
  "risk reward ratio calculator",
  "risk reward calculator",
  "risk to reward ratio forex",
  "rr ratio calculator",
  "trading risk reward calculator",
  "risk reward ratio trading",
  "forex risk reward",
  "what is a good risk reward ratio",
  "1:2 risk reward",
  "ftmo risk reward ratio",
];

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

// Pre-compute R:R reference table
const rrTable = [
  { rr: '1:1',   winRate: '50.1%', trades100: '+$0*',  verdict: 'Minimum viable', color: 'text-slate-400' },
  { rr: '1:1.5', winRate: '40.1%', trades100: '+$50',  verdict: 'Good for high win-rate traders', color: 'text-emerald-400' },
  { rr: '1:2',   winRate: '33.4%', trades100: '+$200', verdict: 'Industry standard', color: 'text-emerald-400' },
  { rr: '1:2.5', winRate: '28.6%', trades100: '+$350', verdict: 'Excellent — trend traders', color: 'text-emerald-300' },
  { rr: '1:3',   winRate: '25.1%', trades100: '+$500', verdict: 'Best in class', color: 'text-emerald-300' },
];

// Break-even win rate by R:R = 1 / (1 + RR)
const breakEven = [
  { rr: '1:0.5', rate: '66.7%' },
  { rr: '1:1',   rate: '50.0%' },
  { rr: '1:1.5', rate: '40.0%' },
  { rr: '1:2',   rate: '33.3%' },
  { rr: '1:2.5', rate: '28.6%' },
  { rr: '1:3',   rate: '25.0%' },
  { rr: '1:4',   rate: '20.0%' },
  { rr: '1:5',   rate: '16.7%' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is a good risk reward ratio in forex?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A 1:2 risk-reward ratio is widely considered the standard for forex trading — risking $1 to make $2. At 1:2, you only need to win 34% of trades to break even. Professional FTMO-funded traders often use 1:1.5 to 1:2 for day trading, where win rates above 40% are achievable.",
      },
    },
    {
      "@type": "Question",
      name: "How do you calculate risk reward ratio?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "R:R Ratio = Potential Profit ÷ Potential Loss. If your stop loss is 30 pips and your take profit is 60 pips, the R:R is 60 ÷ 30 = 1:2. In dollar terms: if you risk $100 to make $200, the R:R is 1:2. The calculator above handles both pip-based and dollar-based inputs.",
      },
    },
    {
      "@type": "Question",
      name: "What win rate do I need for a 1:2 risk reward ratio to be profitable?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "With a 1:2 R:R ratio, you break even at a 33.3% win rate (winning just 1 in every 3 trades). At a 40% win rate: 40 wins × $200 = $8,000 profit vs 60 losses × $100 = $6,000 loss = net $2,000 profit per 100 trades. Formula: Break-even win rate = 1 ÷ (1 + R:R Ratio).",
      },
    },
    {
      "@type": "Question",
      name: "Is 1:1 risk reward ratio good enough?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A 1:1 R:R is viable but requires a win rate above 50% to be profitable (after costs like spreads and commission). Experienced traders who trade high-probability setups with tight stops can use 1:1 effectively. For most traders, a 1:1.5 or 1:2 ratio provides more margin for error.",
      },
    },
    {
      "@type": "Question",
      name: "How does FTMO use risk reward ratio?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "FTMO challenges require 10% profit target with a maximum 10% total drawdown. A 1:2 R:R means each winning trade returns twice the risk — allowing traders to pass challenges while keeping loss rates low. FTMO recommends risking 0.5%–1% per trade, targeting 1:1.5 to 1:2 R:R for consistency.",
      },
    },
  ],
};

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Risk Reward Ratio Calculator",
  description: seoDescription,
  url: canonicalURL,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  creator: { "@type": "Organization", name: "TRADE90", url: site },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Risk Reward Calculator", item: canonicalURL },
  ],
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="py-14 px-4 border-b border-slate-800/50 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-emerald-900/10 via-slate-950 to-slate-950">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-[10px] uppercase tracking-widest text-slate-500 font-bold flex items-center gap-2">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-300">Risk Reward Calculator</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-4">
        Risk Reward <span class="text-emerald-400">Ratio Calculator</span>
      </h1>
      <p class="text-slate-300 text-base leading-relaxed max-w-2xl mb-8">
        Calculate your trade's R:R ratio, find the minimum win rate needed to be profitable, and see the expected value across 100 trades. Used by FTMO-funded and prop firm traders worldwide.
      </p>

      <!-- Interactive R:R calculator (pure JS, no framework needed) -->
      <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 mb-6" id="rr-tool">
        <h2 class="text-white font-black uppercase text-sm tracking-tighter mb-5">
          Calculate R:R Ratio
        </h2>
        <div class="grid sm:grid-cols-2 gap-4 mb-6">
          <div>
            <label for="rr-risk" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">
              Risk Amount ($) or Stop Loss (pips)
            </label>
            <input
              id="rr-risk"
              type="number"
              value="100"
              min="0.01"
              step="any"
              class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white font-mono text-sm focus:outline-none focus:border-emerald-500 transition-colors"
            />
          </div>
          <div>
            <label for="rr-reward" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">
              Reward Amount ($) or Take Profit (pips)
            </label>
            <input
              id="rr-reward"
              type="number"
              value="200"
              min="0.01"
              step="any"
              class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white font-mono text-sm focus:outline-none focus:border-emerald-500 transition-colors"
            />
          </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
          {[
            { id: 'out-ratio',    label: 'R:R Ratio' },
            { id: 'out-breakeven', label: 'Break-even Win Rate' },
            { id: 'out-ev',       label: 'EV per Trade (at 50% WR)' },
            { id: 'out-verdict',  label: 'Verdict' },
          ].map(({ id, label }) => (
            <div class="bg-slate-950 rounded-xl p-4">
              <div id={id} class="text-emerald-400 font-black text-xl font-mono mb-1">—</div>
              <div class="text-slate-500 text-[9px] uppercase tracking-widest font-bold">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── R:R Reference Table ─────────────────────────────────── -->
  <section class="max-w-5xl mx-auto py-16 px-6">
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
      R:R Ratio Reference Table
    </h2>
    <p class="text-slate-400 text-sm mb-8 max-w-2xl leading-relaxed">
      Values assume $100 risk per trade across 100 trades. Break-even win rate = 1 ÷ (1 + R:R). *1:1 at exact 50% win rate = $0 net before costs.
    </p>

    <div class="overflow-x-auto rounded-2xl border border-slate-800 mb-12">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-900/80 border-b border-slate-800">
            {['R:R Ratio', 'Break-even Win Rate', 'Net at 45% Win Rate', 'Verdict'].map(h => (
              <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-widest text-emerald-400">{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rrTable.map(({ rr, winRate, trades100, verdict, color }, i) => (
            <tr class={`border-b border-slate-800/50 ${i % 2 ? 'bg-slate-900/20' : ''}`}>
              <td class="px-5 py-4 font-mono font-black text-white text-base">{rr}</td>
              <td class="px-5 py-4 font-mono text-slate-300">{winRate}</td>
              <td class={`px-5 py-4 font-mono font-bold ${color}`}>{trades100}</td>
              <td class="px-5 py-4 text-slate-400 text-xs">{verdict}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Break-even win rate reference -->
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
      Break-even Win Rate by R:R
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12">
      {breakEven.map(({ rr, rate }) => (
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-4 text-center">
          <div class="text-white font-black text-lg font-mono mb-1">{rr}</div>
          <div class="text-emerald-400 font-mono font-bold text-sm">{rate}</div>
          <div class="text-slate-600 text-[9px] uppercase tracking-widest mt-1">Min Win Rate</div>
        </div>
      ))}
    </div>

    <!-- What is a good R:R -->
    <div class="grid md:grid-cols-2 gap-8 items-start mb-12">
      <div>
        <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-4 border-l-4 border-emerald-500 pl-4">
          What Is a Good Risk Reward Ratio?
        </h2>
        <div class="space-y-3 text-slate-400 text-sm leading-relaxed">
          <p>
            A 1:2 risk-reward ratio is the most widely used standard in professional forex trading. It means you risk $1 to make $2 — and you only need to win 34% of trades to break even. Most experienced traders can maintain a 40–55% win rate, making 1:2 reliably profitable over time.
          </p>
          <p>
            A 1:1 ratio requires winning more than 50% of trades to be profitable after spreads and commissions. This is achievable for high-conviction scalpers but difficult to sustain for swing traders or news traders.
          </p>
          <p>
            FTMO and most prop firms are designed around 1:1.5 to 1:2 R:R strategies. At 1:2, a trader with a 45% win rate on a $100,000 FTMO account risking 1% per trade ($1,000) generates +$11,000 over 100 trades — well above the 10% profit target needed to pass.
          </p>
        </div>
      </div>
      <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
        <h3 class="text-white font-black uppercase text-sm tracking-tighter mb-4">
          FTMO Challenge Example — 1:2 R:R
        </h3>
        <div class="space-y-0 divide-y divide-slate-800/50">
          {[
            ['Account Size', '$100,000'],
            ['Profit Target', '$10,000 (10%)'],
            ['Daily Loss Limit', '$5,000 (5%)'],
            ['Max Drawdown', '$10,000 (10%)'],
            ['Risk Per Trade', '$1,000 (1%)'],
            ['R:R Ratio', '1:2'],
            ['Reward Per Win', '$2,000'],
            ['Break-even Rate', '34%'],
            ['At 45% Win Rate / 100 Trades', '+$11,000 net'],
          ].map(([label, value]) => (
            <div class="flex justify-between items-center py-2.5 text-xs">
              <span class="text-slate-400">{label}</span>
              <span class="font-mono font-bold text-white">{value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-slate-900/70 border border-emerald-500/20 rounded-2xl p-6">
      <h3 class="text-white font-black uppercase tracking-tighter text-lg mb-2">
        Now Calculate Your Exact Lot Size
      </h3>
      <p class="text-slate-400 text-sm mb-5">
        Once you know your R:R ratio and stop loss distance, use the TRADE90 position size calculator to find the exact lot size that keeps your risk within your planned dollar amount.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-black uppercase tracking-widest px-5 py-2.5 rounded-xl transition-colors">
          Position Size Calculator →
        </a>
        <a href="/pip-value-calculator/" class="inline-flex items-center gap-2 border border-slate-700 hover:border-emerald-500/50 text-slate-300 text-xs font-black uppercase tracking-widest px-5 py-2.5 rounded-xl transition-colors">
          Pip Value Calculator
        </a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto pb-20 px-6">
    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-6 border-l-4 border-emerald-500 pl-4">
      Risk Reward Ratio FAQ
    </h2>
    <div class="space-y-3">
      {[
        {
          q: "What is a good risk reward ratio in forex?",
          a: "A 1:2 risk-reward ratio is the professional standard — you risk $1 to make $2. At 1:2, you only need a 34% win rate to break even. For day traders targeting high-probability setups, 1:1.5 is also common. Anything below 1:1 requires a win rate above 50% to be profitable after costs.",
        },
        {
          q: "How do you calculate risk reward ratio?",
          a: "R:R Ratio = Potential Profit ÷ Potential Loss. If your stop loss is 30 pips and take profit is 60 pips, the R:R is 60 ÷ 30 = 1:2. In dollar terms: risking $100 to make $200 is a 1:2 R:R. The calculator above handles both pip-based and dollar inputs.",
        },
        {
          q: "What win rate do I need for a 1:2 R:R ratio?",
          a: "Formula: Break-even win rate = 1 ÷ (1 + R:R ratio) = 1 ÷ 3 = 33.3%. At 40% win rate: 40 wins × $200 = $8,000 profit, 60 losses × $100 = $6,000 loss = net $2,000 profit per 100 trades. The higher your R:R, the less often you need to win.",
        },
        {
          q: "Is 1:1 risk reward good enough?",
          a: "A 1:1 R:R requires a >50% win rate to be profitable after spreads and commissions. Achievable for disciplined scalpers with tight spreads. For most swing traders and funded account traders, 1:1.5 or 1:2 is safer — it provides a larger cushion for losing streaks without failing challenges.",
        },
        {
          q: "How does FTMO use risk reward ratio?",
          a: "FTMO challenges require 10% profit with max 10% drawdown. A 1:2 R:R at 1% risk per trade means each win returns $2,000 on a $100,000 account. At a 45% win rate over 100 trades, this generates $11,000 net — passing the challenge. FTMO traders typically use 1:1.5–1:2 R:R with 0.5%–1% risk per trade.",
        },
      ].map(({ q, a }) => (
        <details class="group bg-slate-900/40 border border-slate-800 hover:border-emerald-500/30 rounded-2xl overflow-hidden transition-colors">
          <summary class="flex justify-between items-center p-5 cursor-pointer font-bold text-slate-200 text-sm uppercase tracking-tight hover:text-white list-none">
            {q}
            <span class="text-emerald-500 group-open:rotate-45 transition-transform text-xl leading-none shrink-0 ml-4">+</span>
          </summary>
          <div class="px-5 pb-5 text-slate-400 text-sm leading-relaxed border-t border-slate-800/50 pt-4">
            {a}
          </div>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  // Pure-JS interactive R:R calculator
  const riskEl    = document.getElementById('rr-risk') as HTMLInputElement;
  const rewardEl  = document.getElementById('rr-reward') as HTMLInputElement;
  const ratioOut  = document.getElementById('out-ratio');
  const beOut     = document.getElementById('out-breakeven');
  const evOut     = document.getElementById('out-ev');
  const vOut      = document.getElementById('out-verdict');

  function calc() {
    const risk   = parseFloat(riskEl?.value ?? '0');
    const reward = parseFloat(rewardEl?.value ?? '0');
    if (!risk || !reward || risk <= 0 || reward <= 0) return;

    const rr     = reward / risk;
    const be     = (1 / (1 + rr)) * 100;
    const ev     = 0.5 * reward - 0.5 * risk;
    const verd   = rr >= 2 ? 'Excellent' : rr >= 1.5 ? 'Good' : rr >= 1 ? 'Minimum' : 'Below standard';

    if (ratioOut) ratioOut.textContent = `1:${rr.toFixed(2)}`;
    if (beOut)    beOut.textContent    = `${be.toFixed(1)}%`;
    if (evOut)    evOut.textContent    = `${ev >= 0 ? '+' : ''}$${ev.toFixed(0)}`;
    if (vOut)     vOut.textContent     = verd;

    if (ratioOut) ratioOut.className = rr >= 1.5 ? 'text-emerald-400 font-black text-xl font-mono mb-1' : 'text-yellow-400 font-black text-xl font-mono mb-1';
  }

  riskEl?.addEventListener('input', calc);
  rewardEl?.addEventListener('input', calc);
  calc();
</script>
