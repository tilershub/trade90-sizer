---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getAllTags, getPosts } from '../../lib/blog';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map((tag) => ({
    params: { tag: tag.toLowerCase().replace(/\s+/g, '-') },
    props: { tagLabel: tag },
  }));
}

const { tag } = Astro.params;
const { tagLabel } = Astro.props;

// Find posts that contain this tag (match on normalised slug)
const allPosts = await getPosts();
const posts = allPosts.filter((p) =>
  p.tags.some((t) => t.toLowerCase().replace(/\s+/g, '-') === tag)
);

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

const seoTitle = `${tagLabel} Analysis & Trading Guides — TRADE90`;
const seoDescription = `${tagLabel} market analysis, volatility reports, and risk framework guides from TRADE90 — institutional intelligence for funded and retail Forex traders in the USA and Europe.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${site}/blog/` },
    { "@type": "ListItem", position: 3, name: tagLabel, item: canonicalURL },
  ],
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={[tagLabel, "forex trading", "trading analysis", "risk management", "position sizing"]}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />

  <section class="max-w-6xl mx-auto py-20 px-6">
    <header class="mb-12 border-l-4 border-emerald-500 pl-6">
      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-2">
        Category
      </p>
      <h1 class="text-4xl font-black uppercase text-white tracking-tighter">{tagLabel}</h1>
      <p class="text-slate-500 uppercase tracking-widest text-[10px] mt-1">
        {posts.length} {posts.length === 1 ? 'Report' : 'Reports'}
      </p>
    </header>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <BlogCard
            title={post.title}
            excerpt={post.excerpt ?? ''}
            image={post.feature_image ?? undefined}
            slug={post.slug}
            date={post.published_at}
            readingTime={post.reading_time ?? undefined}
            tags={post.tags}
            index={i}
          />
        ))}
      </div>
    ) : (
      <div class="py-32 text-center border border-dashed border-slate-800 rounded-3xl">
        <p class="text-slate-600 text-sm italic">No reports in this category yet.</p>
      </div>
    )}

    <div class="mt-12 text-center">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-emerald-500 hover:text-white transition-colors"
      >
        ← All Analysis
      </a>
    </div>
  </section>
</BaseLayout>
