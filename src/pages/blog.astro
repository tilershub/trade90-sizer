---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getPosts } from '../lib/blog';

const posts = await getPosts();

const seoTitle = "Forex & Trading Market Analysis — TRADE90";
const seoDescription = "Institutional-grade Forex, Gold and Crypto market analysis for USA and European traders. Volatility reports, risk framework guides, prop firm strategy, and funded account intelligence from a veteran FTMO-funded trader.";
const keywords = [
  "forex market analysis",
  "trading risk management",
  "FTMO funded trading",
  "prop firm strategy",
  "forex volatility report",
  "gold trading analysis",
  "crypto trading guide",
  "position sizing",
  "forex trading UK",
  "forex trading USA",
];

const site = Astro.site?.toString() || "https://tradeninety.com";
const canonicalURL = new URL(Astro.url.pathname, site).toString();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "Market Analysis", item: canonicalURL },
  ],
};

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "TRADE90 Market Analysis",
  description: seoDescription,
  url: canonicalURL,
  inLanguage: "en",
  publisher: {
    "@type": "Organization",
    name: "TRADE90",
    url: site,
    logo: { "@type": "ImageObject", url: `${site}favicon.svg` },
  },
};
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={keywords}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} slot="head-extra" />

  <section class="max-w-6xl mx-auto py-20 px-6">
    <header class="mb-16">
      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-3">
        Intelligence Feed
      </p>
      <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-4">
        Market <span class="text-emerald-500">Analysis</span>
      </h1>
      <p class="text-slate-500 max-w-xl text-sm uppercase tracking-widest font-bold">
        Institutional Risk Framework Reports — Forex · Gold · Crypto
      </p>
    </header>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post, i) => (
          <BlogCard
            title={post.title}
            excerpt={post.excerpt ?? ''}
            image={post.feature_image ?? undefined}
            slug={post.slug}
            date={post.published_at}
            readingTime={post.reading_time ?? undefined}
            tags={post.tags}
            index={i}
          />
        ))}
      </div>
    ) : (
      <div class="py-32 text-center border border-dashed border-slate-800 rounded-3xl">
        <p class="text-slate-600 text-sm italic">
          New intelligence reports publishing shortly.
        </p>
      </div>
    )}
  </section>
</BaseLayout>
